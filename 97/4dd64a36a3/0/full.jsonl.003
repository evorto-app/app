ostgresql://neon:npg@db:5432/${NEON_DATABASE_NAME:-appdb}?sslmode=require\n      E2E_GLOBAL_ADMIN_AUTH0_IDS:\n      ISSUER_BASE_URL:\n      NEON_LOCAL_PROXY: \"true\"\n      PORT: \"4200\"\n      S3_ACCESS_KEY_ID: \"${S3_ACCESS_KEY_ID:-minioadmin}\"\n      S3_BUCKET: \"${S3_BUCKET:-evorto-testing}\"\n      S3_ENDPOINT: http://minio:9000\n      S3_REGION: \"${S3_REGION:-us-east-1}\"\n      S3_SECRET_ACCESS_KEY: \"${S3_SECRET_ACCESS_KEY:-minioadmin}\"\n      SECRET:\n      SSR_RPC_ORIGIN: http://localhost:4200\n      STRIPE_API_KEY:\n      STRIPE_TEST_ACCOUNT_ID:\n      STRIPE_WEBHOOK_SECRET:\n      STRIPE_WEBHOOK_SECRET_FILE: /run/stripe-webhook/signing-secret\n    command:\n      - /bin/sh\n      - -lc\n      - mkdir -p /app/logs && bun --preload ./instrument.mjs dist/evorto/server/server.mjs 2>&1 | tee -a /app/logs/server.log\n    ports:\n      - \"${APP_HOST_PORT:-4200}:4200\"\n    volumes:\n      - stripe-webhook:/run/stripe-webhook:ro\n\n  stripe:\n    image: stripe/stripe-cli:v1.41.1\n    restart: always\n    environment:\n      STRIPE_API_KEY:\n      STRIPE_DEVICE_NAME: integration-tests\n    entrypoint: /bin/sh\n    command: /usr/local/bin/stripe-listen-docker\n    volumes:\n      - ./helpers/testing/stripe-listen-docker.sh:/usr/local/bin/stripe-listen-docker:ro\n      - stripe-webhook:/run/stripe-webhook\n\nvolumes:\n  stripe-webhook:\n"}}
