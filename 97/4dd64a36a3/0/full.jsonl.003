n env:runtime && dotenv -c dev -- bun helpers/testing/remove-stale-compose-containers.ts\",\n    \"docker:ps\": \"bun run env:runtime && dotenv -c dev -- docker compose ps\",\n    \"docker:stop\": \"bun run env:runtime && dotenv -c dev -- docker compose down\",\n    \"docker:reset\": \"bun run docker:check && dotenv -c dev -- docker compose down\",\n    \"docker:resume\": \"bun run docker:check && dotenv -c dev -- docker compose up --no-recreate -d\",\n    \"docker:start\": \"bun run docker:reset && dotenv -c dev -- docker compose up --build -d\",\n    \"docker:start:watch\": \"bun run docker:reset && dotenv -c dev -- docker compose up --build -w\",\n    \"docker:start:foreground\": \"bun run docker:reset && dotenv -c dev -- docker compose up --build\",\n    \"docker:webserver\": \"bun run docker:check && dotenv -c dev -- docker compose rm --force && dotenv -c dev -- docker compose up --build\",\n    \"db:migrate\": \"bun migration/index.ts\",\n    \"deps:update:angular\": \"bunx --bun ng update @angular/cli @angular/cdk @angular/core @angular/material angular-eslint --allow-dirty\",\n    \"deps:update:drizzle\": \"bun add drizzle-orm@rc && bun add -D drizzle-seed@rc drizzle-kit@rc\",\n    \"ops:stripe:listen\": \"stripe listen --forward-to http://localhost:4200/webhooks/stripe\",\n    \"ops:sentry:sourcemaps\": \"sentry-cli sourcemaps inject --org lukas-heddendorp --project evorto ./dist && sentry-cli sourcemaps upload --org lukas-heddendorp --project evorto ./dist\",\n    \"ui:theme:generate\": \"bunx --bun ng generate @angular/material:theme-color --include-high-contrast --primary-color=#0891b2 --interactive=false --directory=src/ --force\",\n    \"ui:theme:generate:esn\": \"bunx --bun ng generate @angular/material:theme-color --include-high-contrast --primary-color=#00aeef --secondary-color=#ec008c --tertiary-color=#7ac143 --interactive=false --directory=src/_esn --force\",\n    \"test:cleanup:receipt-images\": \"bun helpers/cleanup-testing-receipt-images.ts\",\