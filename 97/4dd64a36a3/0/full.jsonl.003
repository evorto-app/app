              <dt class=\"text-on-surface-variant\">\n                        Available quantity\n                      </dt>\n                      <dd>{{ addOn.totalAvailableQuantity }}</dd>\n                    </div>\n                    <div>\n                      <dt class=\"text-on-surface-variant\">Max per user</dt>\n                      <dd>{{ addOn.maxQuantityPerUser }}</dd>\n                    </div>\n                    <div>\n                      <dt class=\"text-on-surface-variant\">Purchase timing</dt>\n                      <dd>{{ eventAddonPurchaseTiming(addOn) }}</dd>\n                    </div>\n                    <div>\n                      <dt class=\"text-on-surface-variant\">\n                        Registration options\n                      </dt>\n                      <dd>\n                        @for (\n                          option of addOn.registrationOptions;\n                          track option.registrationOptionId\n                        ) {\n                          <span>\n                            {{\n                              registrationOptionTitle(\n                                eventQuery.data(),\n                                option.registrationOptionId\n                              )\n                            }}\n                            ({{ option.quantity }})\n                          </span>\n                        }\n                      </dd>\n                    </div>\n                  </dl>\n                </article>\n              }\n            </div>\n          </section>\n        }\n\n        <section class=\"flex flex-col gap-4\">\n          <h2 class=\"headline-small\">Registration</h2>\n          @if (registrationStatusQuery.isPending()) {\n            <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n              <h3 class=\"title-small\">Loading registration status…</h3>\n            </div>\n          } @else if (registrationStatusQuery.isError()) {\n            <div\n              class=\"bg-error-container text-on-error-container rounded-2xl p-4\"\n            >\n              <h3 class=\"title-small\">Failed to load registration status.</h3>\n            </div>\n          } @else if (registrationStatusQuery.isSuccess()) {\n            @if (registrationStatusQuery.data().isRegistered) {\n              <app-event-active-registration\n                [registrations]=\"registrationStatusQuery.data().registrations\"\n              />\n            } @else {\n              @if (transferCode(); as currentTransferCode) {\n                <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n                  <h3 class=\"title-medium\">Use transfer code</h3>\n                  <p class=\"body-medium text-on-surface-variant mt-2\">\n                    This transfer code starts a replacement paid registration.\n                    After checkout succeeds, Evorto confirms the replacement\n                    registration, cancels the original registration, and handles\n                    the source refund path.\n                  </p>\n                  <p class=\"body-small text-on-surface-variant mt-2 font-mono\">\n                    {{ currentTransferCode }}\n                  </p>\n                  <button\n                    class=\"mt-3\"\n                    mat-flat-button\n                    (click)=\"redeemTransferCode()\"\n                    [disabled]=\"\n                      transferCodeRedemptionActionDisabled({\n                        hasTransferCode: !!currentTransferCode,\n                        isRegistered:\n                          registrationStatusQuery.data().isRegistered,\n                        mutationPending:\n                          registerWithTransferCodeMutation.isPending(),\n                      })\n                    \"\n                  >\n                    Register with transfer code\n                  </button>\n                </div>\n              }\n              @switch (registrationOptionsState()) {\n                @case (\"visible\") {\n                  <div class=\"grid grid-cols-1 gap-4 md:grid-cols-2\">\n                    @for (\n                      registrationOption of eventQuery.data()\n                        .registrationOptions;\n                      track registrationOption.id\n                    ) {\n                      <app-event-registration-option\n                        [addOns]=\"\n                          eventAddonsForRegistrationOption(\n                            eventQuery.data(),\n                            registrationOption.id\n                          )\n                        \"\n                        [registrationOption]=\"registrationOption\"\n                      />\n                    }\n                  </div>\n                }\n                @case (\"hiddenByEligibility\") {\n                  <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n                    <h3 class=\"title-small\">Registration unavailable</h3>\n                    <p class=\"body-medium text-on-surface-variant mt-2\">\n                      This event is visible from the direct link, but your\n                      account is not eligible for the available registration\n                      options.\n                    </p>\n                  </div>\n                }\n                @case (\"none\") {\n                  <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n                    <h3 class=\"title-small\">No registration options</h3>\n                    <p class=\"body-medium text-on-surface-variant mt-2\">\n                      This event does not currently offer registration through\n                      the app.\n                    </p>\n                  </div>\n                }\n              }\n            }\n          }\n          @if (registerWithTransferCodeMutation.isError()) {\n            <div\n              class=\"bg-error text-on-error mt-4 flex flex-col gap-2 rounded-2xl p-4\"\n            >\n              <h3 class=\"title-medium\">Transfer code registration failed</h3>\n              <p>\n                {{\n                  transferCodeErrorMessage(\n                    registerWithTransferCodeMutation.error()\n                  )\n                }}\n              </p>\n            </div>\n          }\n        </section>\n      </div>\n    }\n  </div>\n</div>\n"}}
