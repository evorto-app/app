{"timestamp":"2026-06-05T10:12:27.089Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_do6npEaG5dNkdFvYFd1Bucab","output":"Chunk ID: 3f8c33\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 5431\nOutput:\n<div\n  class=\"grid grid-cols-1 lg:relative lg:h-full lg:grid-cols-[400px_1fr] lg:gap-4\"\n>\n  <div class=\"lg:h-full lg:overflow-y-auto lg:rounded-t-lg lg:p-4\">\n    <div\n      class=\"mb-4 {{\n        outletActive() ? 'hidden' : 'flex'\n      }} lg:flex w-full flex-row items-center gap-2 p-2 lg:p-0\"\n    >\n      <h1 class=\"title-large\">Events</h1>\n      <div class=\"grow\"></div>\n      <a\n        mat-button\n        routerLink=\"/templates\"\n        *appIfAnyPermission=\"['events:create']\"\n        class=\"hidden! lg:flex!\"\n      >\n        Create Event\n      </a>\n      <button\n        mat-icon-button\n        aria-label=\"Open event filters\"\n        (click)=\"openFilterPanel()\"\n        *appIfAnyPermission=\"['events:seeDrafts', 'events:seeUnlisted']\"\n      >\n        <fa-icon [icon]=\"faFilter\" />\n      </button>\n      <button\n        mat-icon-button\n        aria-label=\"Open event list actions\"\n        [matMenuTriggerFor]=\"menu\"\n      >\n        <fa-icon [icon]=\"faEllipsisVertical\" />\n      </button>\n      <mat-menu #menu=\"matMenu\">\n        <a\n          routerLink=\"/templates\"\n          mat-menu-item\n          *appIfAnyPermission=\"['events:create']\"\n        >\n          Create Event\n        </a>\n      </mat-menu>\n    </div>\n    <nav\n      class=\"{{\n        outletActive() ? 'hidden' : 'flex'\n      }} lg:flex flex-col gap-2 px-2 lg:px-0\"\n    >\n      @if (eventQuery.isPending()) {\n        <div\n          class=\"bg-surface text-on-surface animate-pulse rounded-2xl px-4 py-2\"\n        >\n          <p class=\"headline-small\">Loading…</p>\n        </div>\n      } @else if (eventQuery.isError()) {\n        <p>Error: {{ eventErrorMessage() }}</p>\n      } @else if (eventQuery.isSuccess()) {\n        @for (day of eventQuery.data(); track day.day) {\n          <p\n            class=\"title-medium sticky top-0 lg:-top-4 z-10 bg-surface-container px-4 py-2\"\n          >\n            {{ day.day | date }}\n          </p>\n          @for (event of day.events; track event.id) {\n            <a\n              routerLink=\"{{ event.id }}\"\n              class=\"rounded-2xl bg-surface px-4 py-2 text-on-surface relative overflow-hidden {{\n                event.userRegistered\n                  ? 'ring-3 ring-inset ring-success'\n                  : event.userIsCreator\n                    ? 'ring-3 ring-inset ring-tertiary'\n                    : ''\n              }}\"\n              routerLinkActive=\"bg-secondary-container! text-on-secondary-container!\"\n            >\n              @switch (event.status) {\n                @case (\"DRAFT\") {\n                  <div class=\"absolute right-0 top-0 h-16 w-16\">\n                    <div\n                      class=\"body-small bg-warn text-on-warn absolute -right-9 top-3 w-28 rotate-45 transform py-1 text-center\"\n                    >\n                      draft\n                    </div>\n                  </div>\n                }\n                @case (\"PENDING_REVIEW\") {\n                  <div class=\"absolute right-0 top-0 h-16 w-16\">\n                    <div\n                      class=\"body-small bg-tertiary-container text-on-tertiary-container absolute -right-9 top-3 w-28 rotate-45 transform py-1 text-center\"\n                    >\n                      pending review\n                    </div>\n                  </div>\n                }\n                @case (\"REJECTED\") {\n                  <div class=\"absolute right-0 top-0 h-16 w-16\">\n                    <div\n                      class=\"body-small bg-error-container text-on-error-container absolute -right-9 top-3 w-28 rotate-45 transform py-1 text-center\"\n                    >\n                      rejected\n                    </div>\n                  </div>\n                }\n              }\n              <div class=\"flex flex-row items-start gap-4\">\n                <app-icon [iconCommonName]=\"event.icon\" size=\"32\" />\n                <div class=\"flex flex-col gap-2\">\n                  <h2 class=\"headline-small\">{{ event.title }}</h2>\n                  <div class=\"flex flex-row flex-wrap items-center gap-4\">\n                    <div class=\"flex flex-row items-center gap-2\">\n                      <fa-icon [icon]=\"faClock\" />\n                      <p>{{ event.start | date: \"shortTime\" }}</p>\n                    </div>\n                    @if (event.unlisted) {\n                      <div class=\"flex flex-row items-center gap-2\">\n                        <fa-icon [icon]=\"faEyeSlash\" />\n                        <p>unlisted</p>\n                      </div>\n                    }\n                  </div>\n                </div>\n              </div>\n            </a>\n          }\n        } @empty {\n          <p>No events found</p>\n        }\n      }\n    </nav>\n  </div>\n  <div class=\"lg:h-full lg:pr-4\">\n    <router-outlet\n      (activate)=\"outletActive.set(true)\"\n      (deactivate)=\"outletActive.set(false)\"\n    />\n  </div>\n</div>\n<div\n  class=\"lg:min-h-full\"\n  appMaterialTheme\n  [baseColor]=\"eventQuery.data()?.icon?.iconColor\"\n>\n  <header\n    class=\"bg-primary-container text-on-primary-container p-4 lg:rounded-t-lg\"\n  >\n    <div\n      class=\"flex flex-col lg:flex-row-reverse lg:items-start lg:justify-between\"\n    >\n      <div class=\"mb-4 flex w-full flex-row items-center gap-2 lg:mb-0 lg:w-10\">\n        <a\n          routerLink=\"/events\"\n          mat-icon-button\n          class=\"lg:hidden! block\"\n          aria-label=\"Back to events\"\n        >\n          <fa-icon [icon]=\"faArrowLeft\" />\n        </a>\n        <div class=\"grow\"></div>\n        @if (eventQuery.isSuccess()) {\n          <button\n            title=\"menu\"\n            *appIfAnyPermission=\"['events:changeListing']\"\n            mat-icon-button\n            [matMenuTriggerFor]=\"menu\"\n            aria-label=\"Open event actions\"\n          >\n            <fa-icon [icon]=\"faEllipsisVertical\" />\n          </button>\n          <mat-menu #menu=\"matMenu\">\n            <button\n              mat-menu-item\n              (click)=\"updateVisibility()\"\n              [disabled]=\"\n                eventListingActionDisabled({\n                  eventLoaded: true,\n                  mutationPending: updateListingMutation.isPending(),\n                })\n              \"\n            >\n              Update listing\n            </button>\n          </mat-menu>\n        }\n      </div>\n      <h1 class=\"display-small\">\n        @if (eventQuery.isSuccess()) {\n          {{ eventQuery.data().title }}\n        } @else if (eventQuery.isPending()) {\n          Loading event ...\n        } @else {\n          Event unavailable\n        }\n      </h1>\n    </div>\n    <div class=\"flex justify-center\">\n      <app-shape\n        [changeSignal]=\"eventQuery.data()?.icon\"\n        class=\"text-secondary w-42 mt-8\"\n      >\n        @if (eventQuery.isSuccess()) {\n          <app-icon [iconCommonName]=\"eventQuery.data().icon\" size=\"100\" />\n        }\n      </app-shape>\n    </div>\n  </header>\n  <div\n    class=\"bg-surface-container-high text-on-surface-container-high flex items-center justify-between gap-4 p-2\"\n  >\n    @if (eventQuery.isSuccess() && cardExpiresBeforeEvent()) {\n      <div\n        class=\"bg-warn-container text-on-warn-container rounded px-3 py-2 body-small\"\n      >\n        Your discount card expires before the event starts. Discounted prices\n        may not apply.\n      </div>\n    }\n    @if (eventQuery.isSuccess()) {\n      @if (canOrganize()) {\n        <a routerLink=\"organize\" matButton=\"filled\">Organize this event</a>\n      }\n      @if (canSeeStatus()) {\n        <div\n          class=\"bg-surface text-on-surface flex flex-col gap-4 rounded-md p-2 lg:flex-row\"\n        >\n          <div class=\"flex gap-2 lg:items-center\">\n            <app-event-status\n              [status]=\"eventQuery.data().status\"\n              [comment]=\"eventQuery.data().statusComment\"\n              [reviewer]=\"\n                eventQuery.data().reviewer?.firstName +\n                ' ' +\n                eventQuery.data().reviewer?.lastName\n              \"\n            />\n            @if (!canEdit() && eventQuery.data().status !== \"APPROVED\") {\n              <span class=\"text-on-surface-variant text-sm\">\n                (Event is locked for editing)\n              </span>\n            }\n          </div>\n          @if (eventQuery.data().unlisted) {\n            <div\n              class=\"bg-secondary-container text-on-secondary-container rounded px-3 py-2 body-small\"\n            >\n              Unlisted: hidden from event lists, but eligible people with the\n              direct link can still open it.\n            </div>\n          }\n\n          <div class=\"flex flex-col gap-2 lg:flex-row lg:items-center lg:gap-4\">\n            @if (canReview() && eventQuery.data().status === \"PENDING_REVIEW\") {\n              <button\n                matButton=\"outlined\"\n                (click)=\"reviewEvent(false)\"\n                [disabled]=\"\n                  eventReviewActionDisabled({\n                    canReview: canReview(),\n                    mutationPending: reviewMutation.isPending(),\n                    status: eventQuery.data().status,\n                  })\n                \"\n              >\n                Reject\n              </button>\n              <button\n                matButton=\"filled\"\n                (click)=\"reviewEvent(true)\"\n                [disabled]=\"\n                  eventReviewActionDisabled({\n                    canReview: canReview(),\n                    mutationPending: reviewMutation.isPending(),\n                    status: eventQuery.data().status,\n                  })\n                \"\n              >\n                Approve\n              </button>\n            }\n\n            @if (canEdit()) {\n              <a matButton=\"tonal\" routerLink=\"edit\"> Edit Event </a>\n            }\n\n            @if (\n              canEdit() &&\n              (eventQuery.data().status === \"DRAFT\" ||\n                eventQuery.data().status === \"REJECTED\")\n            ) {\n              <button\n                matButton=\"filled\"\n                (click)=\"submitForReview()\"\n                [disabled]=\"\n                  eventSubmitForReviewActionDisabled({\n                    canEdit: canEdit(),\n                    mutationPending: submitForReviewMutation.isPending(),\n                    status: eventQuery.data().status,\n                  })\n                \"\n              >\n                Submit for Review\n              </button>\n            }\n          </div>\n        </div>\n      }\n    }\n  </div>\n  <div class=\"flex flex-col gap-4\">\n    @if (eventQuery.isPending()) {\n      <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n        <h2 class=\"title-medium\">Loading event ...</h2>\n      </div>\n    } @else if (eventQuery.isError()) {\n      <div class=\"bg-error-container text-on-error-container rounded-2xl p-4\">\n        Failed to load event.\n      </div>\n    } @else if (eventQuery.isSuccess()) {\n      <div class=\"flex flex-col gap-4\">\n        <section\n          class=\"bg-surface text-on-surface description rounded-b-lg p-4\"\n        >\n          <div\n            class=\"prose dark:prose-invert max-w-none\"\n            [innerHTML]=\"eventQuery.data().description\"\n          ></div>\n        </section>\n\n        @if (eventQuery.data().addOns.length > 0) {\n          <section class=\"bg-surface text-on-surface rounded-2xl p-4\">\n            <h2 class=\"headline-small mb-4\">Add-ons</h2>\n            <div class=\"grid gap-4\">\n              @for (addOn of eventQuery.data().addOns; track addOn.id) {\n                <article class=\"border-outline-variant border-t pt-3\">\n                  <div class=\"flex flex-wrap items-start justify-between gap-3\">\n                    <div>\n                      <h3 class=\"title-medium\">{{ addOn.title }}</h3>\n                      @if (addOn.description) {\n                        <p class=\"text-on-surface-variant body-medium mt-1\">\n                          {{ addOn.description }}\n                        </p>\n                      }\n                    </div>\n                    <div class=\"text-right\">\n                      @if (addOn.isPaid) {\n                        <app-price-with-tax\n                          [amount]=\"addOn.price\"\n                          [taxRate]=\"eventAddonTaxRate(addOn)\"\n                        />\n                      } @else {\n                        <span>Free</span>\n                      }\n                    </div>\n                  </div>\n                  <dl class=\"mt-3 grid gap-2 text-sm sm:grid-cols-2\">\n                    <div>\n                      <dt class=\"text-on-surface-variant\">\n                        Available quantity\n                      </dt>\n                      <dd>{{ addOn.totalAvailableQuantity }}</dd>\n                    </div>\n                    <div>\n                      <dt class=\"text-on-surface-variant\">Max per user</dt>\n                      <dd>{{ addOn.maxQuantityPerUser }}</dd>\n                    </div>\n                    <div>\n                      <dt class=\"text-on-surface-variant\">Purchase timing</dt>\n                      <dd>{{ eventAddonPurchaseTiming(addOn) }}</dd>\n                    </div>\n                    <div>\n                      <dt class=\"text-on-surface-variant\">\n                        Registration options\n                      </dt>\n                      <dd>\n                        @for (\n                          option of addOn.registrationOptions;\n                          track option.registrationOptionId\n                        ) {\n                          <span>\n                            {{\n                              registrationOptionTitle(\n                                eventQuery.data(),\n                                option.registrationOptionId\n                              )\n                            }}\n                            ({{ option.quantity }})\n                          </span>\n                        }\n                      </dd>\n                    </div>\n                  </dl>\n                </article>\n              }\n            </div>\n          </section>\n        }\n\n        <section class=\"flex flex-col gap-4\">\n          <h2 class=\"headline-small\">Registration</h2>\n          @if (registrationStatusQuery.isPending()) {\n            <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n              <h3 class=\"title-small\">Loading registration status…</h3>\n            </div>\n          } @else if (registrationStatusQuery.isError()) {\n            <div\n              class=\"bg-error-container text-on-error-container rounded-2xl p-4\"\n            >\n              <h3 class=\"title-small\">Failed to load registration status.</h3>\n            </div>\n          } @else if (registrationStatusQuery.isSuccess()) {\n            @if (registrationStatusQuery.data().isRegistered) {\n              <app-event-active-registration\n                [registrations]=\"registrationStatusQuery.data().registrations\"\n              />\n            } @else {\n              @if (transferCode(); as currentTransferCode) {\n                <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n                  <h3 class=\"title-medium\">Use transfer code</h3>\n                  <p class=\"body-medium text-on-surface-variant mt-2\">\n                    This transfer code starts a replacement paid registration.\n                    After checkout succeeds, Evorto confirms the replacement\n                    registration, cancels the original registration, and handles\n                    the source refund path.\n                  </p>\n                  <p class=\"body-small text-on-surface-variant mt-2 font-mono\">\n                    {{ currentTransferCode }}\n                  </p>\n                  <button\n                    class=\"mt-3\"\n                    mat-flat-button\n                    (click)=\"redeemTransferCode()\"\n                    [disabled]=\"\n                      transferCodeRedemptionActionDisabled({\n                        hasTransferCode: !!currentTransferCode,\n                        isRegistered:\n                          registrationStatusQuery.data().isRegistered,\n                        mutationPending:\n                          registerWithTransferCodeMutation.isPending(),\n                      })\n                    \"\n                  >\n                    Register with transfer code\n                  </button>\n                </div>\n              }\n              @switch (registrationOptionsState()) {\n                @case (\"visible\") {\n                  <div class=\"grid grid-cols-1 gap-4 md:grid-cols-2\">\n                    @for (\n                      registrationOption of eventQuery.data()\n                        .registrationOptions;\n                      track registrationOption.id\n                    ) {\n                      <app-event-registration-option\n                        [addOns]=\"\n                          eventAddonsForRegistrationOption(\n                            eventQuery.data(),\n                            registrationOption.id\n                          )\n                        \"\n                        [registrationOption]=\"registrationOption\"\n                      />\n                    }\n                  </div>\n                }\n                @case (\"hiddenByEligibility\") {\n                  <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n                    <h3 class=\"title-small\">Registration unavailable</h3>\n                    <p class=\"body-medium text-on-surface-variant mt-2\">\n                      This event is visible from the direct link, but your\n                      account is not eligible for the available registration\n                      options.\n                    </p>\n                  </div>\n                }\n                @case (\"none\") {\n                  <div class=\"bg-surface text-on-surface rounded-2xl p-4\">\n                    <h3 class=\"title-small\">No registration options</h3>\n                    <p class=\"body-medium text-on-surface-variant mt-2\">\n                      This event does not currently offer registration through\n                      the app.\n                    </p>\n                  </div>\n                }\n              }\n            }\n          }\n          @if (registerWithTransferCodeMutation.isError()) {\n            <div\n              class=\"bg-error text-on-error mt-4 flex flex-col gap-2 rounded-2xl p-4\"\n            >\n              <h3 class=\"title-medium\">Transfer code registration failed</h3>\n              <p>\n                {{\n                  transferCodeErrorMessage(\n                    registerWithTransferCodeMutation.error()\n                  )\n                }}\n              </p>\n            </div>\n          }\n        </section>\n      </div>\n    }\n  </div>\n</div>\n<div class=\"mb-4 flex w-full flex-row items-center gap-2\">\n  <a\n    routerLink=\"/events/{{ eventId() }}\"\n    mat-icon-button\n    aria-label=\"Back to event\"\n  >\n    <fa-icon [icon]=\"faArrowLeft\" />\n  </a>\n  <h1 class=\"title-large\">\n    @if (eventQuery.isSuccess()) {\n      {{ eventQuery.data().title }}\n    } @else {\n      Edit event\n    }\n  </h1>\n  <div class=\"grow\"></div>\n  @if (eventQuery.isSuccess()) {\n    <button\n      title=\"menu\"\n      aria-label=\"Open event edit actions\"\n      *appIfAnyPermission=\"['events:changeListing']\"\n      mat-icon-button\n      [matMenuTriggerFor]=\"menu\"\n    >\n      <fa-icon [icon]=\"faEllipsisVertical\" />\n    </button>\n    <mat-menu #menu=\"matMenu\">\n      <!--    <button mat-menu-item (click)=\"updateVisibility()\">-->\n      <!--      Update visibility-->\n      <!--    </button>-->\n    </mat-menu>\n  }\n</div>\n<main>\n  @if (eventQuery.isPending()) {\n    <div\n      class=\"bg-surface text-on-surface flex animate-pulse cursor-progress flex-col gap-2 rounded-2xl p-4\"\n    >\n      <h2 class=\"title-medium\">Loading event ...</h2>\n    </div>\n  } @else if (eventQuery.isError()) {\n    <div class=\"bg-error-container text-on-error-container rounded-2xl p-4\">\n      Failed to load event.\n    </div>\n  } @else if (eventQuery.isSuccess()) {\n    <form (submit)=\"saveEvent($event)\">\n      <div class=\"grid gap-6\">\n        <section class=\"bg-surface text-on-surface rounded-2xl p-4\">\n          <h2 class=\"title-large mb-4\">Event Details</h2>\n          <app-event-general-form [generalForm]=\"editEventForm\" />\n        </section>\n\n        <section\n          class=\"bg-surface-container-high text-on-surface-container-high rounded-2xl p-2\"\n        >\n          <h2 class=\"title-large mb-4 p-2\">Registration Options</h2>\n          <div\n            class=\"grid grid-cols-1 gap-6 lg:grid-cols-2 lg:[grid-template-rows:auto_auto_auto_auto_auto_auto_auto]\"\n          >\n            @for (option of editEventForm.registrationOptions; track option) {\n              <app-registration-option-form\n                class=\"bg-surface text-on-surface rounded-xl p-4 grid gap-4 lg:row-span-7 lg:grid-rows-subgrid\"\n                [esnEnabled]=\"esnEnabled()\"\n                [registrationOptionForm]=\"option\"\n                [registrationModes]=\"registrationModes\"\n              />\n            }\n          </div>\n        </section>\n\n        <div class=\"flex justify-end\">\n          <button\n            type=\"submit\"\n            mat-button\n            [disabled]=\"\n              eventEditSubmitDisabled({\n                formInvalid: editEventForm().invalid(),\n                formSubmitting: editEventForm().submitting(),\n                mutationPending: updateEventMutation.isPending(),\n              })\n            \"\n          >\n            @if (updateEventMutation.isPending()) {\n              Saving...\n            } @else {\n              Save Changes\n            }\n          </button>\n          @if (updateEventMutation.error()) {\n            <div class=\"text-error mt-2 text-sm\">\n              Failed to save event. Please try again.\n            </div>\n          }\n        </div>\n      </div>\n    </form>\n  }\n</main>\n"}}
{"timestamp":"2026-06-05T10:12:27.090Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_FIS0nHdrK6Al7G22RIDaXtMV","output":"Chunk ID: 94ed9f\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 1520\nOutput:\n<div class=\"grid grid-cols-1 lg:h-full lg:grid-cols-[450px_1fr] lg:gap-4\">\n  <div\n    class=\"max-h-[calc(100dvh-13rem)] overflow-y-auto pr-1 lg:h-full lg:max-h-none lg:overflow-y-auto lg:py-4 lg:pr-4\"\n  >\n    <div\n      class=\"mb-4 {{\n        outletActive() ? 'hidden' : 'flex'\n      }} lg:flex w-full flex-row items-center gap-2\"\n    >\n      <h1 class=\"title-large\">Event templates</h1>\n      <div class=\"grow\"></div>\n      <a mat-button routerLink=\"categories\" class=\"hidden! lg:flex!\">\n        Manage categories\n      </a>\n      <button\n        class=\"lg:hidden!\"\n        title=\"menu\"\n        aria-label=\"Open template list actions\"\n        mat-icon-button\n        [matMenuTriggerFor]=\"menu\"\n      >\n        <fa-icon [icon]=\"faEllipsisVertical\" />\n      </button>\n      <mat-menu #menu=\"matMenu\">\n        <a routerLink=\"categories\" mat-menu-item>Manage categories</a>\n        <!-- <a routerLink=\"../create\" mat-menu-item>Create template</a> -->\n      </mat-menu>\n    </div>\n    <nav\n      class=\"{{ outletActive() ? 'hidden' : 'flex' }} lg:flex flex-col gap-4\"\n    >\n      @if (templateQuery.isPending()) {\n        <div\n          class=\"bg-surface text-on-surface flex animate-pulse cursor-progress flex-col gap-2 rounded-2xl p-4\"\n        >\n          <h2 class=\"title-medium\">Loading ...</h2>\n        </div>\n      } @else if (templateQuery.isError()) {\n        <p>Error: {{ templateQueryErrorMessage() }}</p>\n      } @else if (templateQuery.isSuccess()) {\n        <a mat-flat-button routerLink=\"create\" class=\"hidden! lg:flex!\">\n          Create template\n        </a>\n        @for (\n          templateCategory of templateQuery.data();\n          track templateCategory.id\n        ) {\n          <div\n            class=\"bg-surface text-on-surface flex flex-col gap-2 rounded-2xl p-4\"\n          >\n            <div class=\"mb-4 flex min-w-0 flex-row items-start gap-4\">\n              <app-icon [iconCommonName]=\"templateCategory.icon\" size=\"28\" />\n              <h2 class=\"title-large min-w-0 break-words\">\n                {{ templateCategory.title }}\n              </h2>\n            </div>\n            @for (template of templateCategory.templates; track template.id) {\n              <a\n                class=\"title-medium flex min-w-0 flex-row items-start gap-2 rounded-full p-2\"\n                routerLink=\"{{ template.id }}\"\n                routerLinkActive=\"bg-secondary-container! text-on-secondary-container!\"\n              >\n                <app-icon [iconCommonName]=\"template.icon\" size=\"24\" />\n                <span class=\"min-w-0 break-words\">{{ template.title }}</span>\n              </a>\n            } @empty {\n              <p>No templates found in this category</p>\n              <a mat-button routerLink=\"create/{{ templateCategory.id }}\">\n                Add template to this category\n              </a>\n            }\n          </div>\n        } @empty {\n          <p>No template categories found</p>\n        }\n      }\n    </nav>\n  </div>\n  <div class=\"lg:h-full lg:overflow-y-auto lg:p-4\">\n    <router-outlet\n      (activate)=\"outletActive.set(true)\"\n      (deactivate)=\"outletActive.set(false)\"\n    />\n  </div>\n</div>\n\n<a\n  routerLink=\"create\"\n  class=\"fab-fixed {{ outletActive() ? 'hidden!' : 'block' }} lg:hidden!\"\n  mat-fab\n  extended\n>\n  <fa-icon [icon]=\"faPlus\" />\n  Create template\n</a>\n<div class=\"mb-4 flex flex-row items-center gap-2\">\n  <a routerLink=\"..\" mat-icon-button aria-label=\"Back to template details\">\n    <fa-icon [icon]=\"faArrowLeft\" />\n  </a>\n  <h1 class=\"title-large\">\n    @if (templateQuery.isSuccess()) {\n      Create {{ templateQuery.data().title }} event\n    } @else {\n      Create event from template\n    }\n  </h1>\n</div>\n\n<main class=\"flex flex-col gap-6\">\n  @if (templateQuery.isPending()) {\n    <div\n      class=\"bg-surface text-on-surface flex animate-pulse cursor-progress flex-col gap-2 rounded-2xl p-4\"\n    >\n      <h2 class=\"title-medium\">Loading template ...</h2>\n    </div>\n  } @else if (templateQuery.isError()) {\n    <div class=\"bg-error-container text-on-error-container rounded-2xl p-4\">\n      Failed to load template.\n    </div>\n  } @else if (templateQuery.isSuccess()) {\n    @if (addOnCopyNotice(); as notice) {\n      <aside\n        class=\"border-outline-variant bg-surface-container-low text-on-surface rounded-lg border p-4\"\n      >\n        <div class=\"flex items-start gap-3\">\n          <fa-icon class=\"text-primary mt-1\" [icon]=\"faCircleInfo\" />\n          <p class=\"body-medium\">{{ notice }}</p>\n        </div>\n      </aside>\n    }\n\n    <form (submit)=\"onSubmit($event)\">\n      <div class=\"grid gap-6\">\n        <section class=\"bg-surface text-on-surface rounded-2xl p-4\">\n          <h2 class=\"title-large mb-4\">Event Details</h2>\n          <app-event-general-form [generalForm]=\"createEventForm\" />\n        </section>\n\n        <section\n          class=\"bg-surface-container-high text-on-surface-container-high rounded-2xl p-2\"\n        >\n          <h2 class=\"title-large mb-4 p-2\">Registration Options</h2>\n          <div\n            class=\"grid grid-cols-1 gap-6 lg:grid-cols-2 lg:[grid-template-rows:auto_auto_auto_auto_auto_auto_auto]\"\n          >\n            @for (option of createEventForm.registrationOptions; track option) {\n              <app-registration-option-form\n                class=\"bg-surface text-on-surface rounded-xl p-4 grid gap-4 lg:row-span-7 lg:grid-rows-subgrid\"\n                [esnEnabled]=\"esnEnabled()\"\n                [registrationOptionForm]=\"option\"\n                [registrationModes]=\"registrationModes\"\n              />\n            }\n          </div>\n        </section>\n\n        <div class=\"flex justify-end\">\n          <button\n            type=\"submit\"\n            mat-button\n            [disabled]=\"\n              templateCreateEventSubmitDisabled({\n                formInvalid: createEventForm().invalid(),\n                formSubmitting: createEventForm().submitting(),\n                mutationPending: createEventMutation.isPending(),\n              })\n            \"\n          >\n            Create event\n          </button>\n        </div>\n      </div>\n    </form>\n  }\n</main>\n"}}
