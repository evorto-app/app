{"timestamp":"2026-06-05T09:57:47.481Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_kz4SB5qW5fRgg2piZZLsGB5g","output":"Chunk ID: 550ade\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 2104\nOutput:\n        with:\n          path: node_modules\n          key: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-primary-key }}\n\n      - name: Install Playwright browsers\n        run: node_modules/.bin/playwright install --with-deps chromium\n\n      - name: Prepare Neon Local metadata directory\n        run: |\n          rm -rf \"${NEON_LOCAL_METADATA_DIR}\"\n          mkdir -p \"${NEON_LOCAL_METADATA_DIR}\"\n          chmod 0777 \"${NEON_LOCAL_METADATA_DIR}\"\n\n      - name: Start Docker stack for E2E\n        timeout-minutes: 25\n        run: bash helpers/testing/ci-start-docker-stack.sh\n\n      - name: Confirm Neon branch expiration\n        run: bun helpers/testing/set-neon-local-branch-expiration.ts\n\n      - name: Wait for application\n        run: |\n          ready_url=\"${BASE_URL}${APP_READY_PATH}\"\n          for attempt in $(seq 1 60); do\n            if curl --fail --silent --show-error \"${ready_url}\" >/dev/null; then\n              echo \"Application is reachable at ${ready_url}\"\n              exit 0\n            fi\n            sleep 2\n          done\n          echo \"::error::Application did not become reachable at ${ready_url} within 120 seconds\"\n          node_modules/.bin/dotenv -c dev -- docker compose ps\n          node_modules/.bin/dotenv -c dev -- docker compose logs --no-color --tail=100\n          exit 1\n\n      - name: Run Playwright functional suite\n        if: startsWith(matrix.suite, 'functional-')\n        timeout-minutes: 40\n        env:\n          E2E_SELECTED_PROJECTS: local-chrome-baseline\n        run: |\n          mkdir -p test-results/docker-logs\n          if [ \"${ACTIONS_STEP_DEBUG:-false}\" = \"true\" ]; then\n            node_modules/.bin/dotenv -c dev -- docker compose logs -f --no-color 2>&1 | tee test-results/docker-logs/live-docker.log &\n            LOG_STREAM_PID=$!\n            cleanup() {\n              if [ -n \"${LOG_STREAM_PID:-}\" ] && kill -0 \"${LOG_STREAM_PID}\" 2>/dev/null; then\n                kill \"${LOG_STREAM_PID}\" || true\n                wait \"${LOG_STREAM_PID}\" || true\n              fi\n            }\n            trap cleanup EXIT\n          fi\n\n          if [ \"${{ matrix.suite }}\" = \"functional-1\" ]; then\n            node_modules/.bin/playwright test --project=local-chrome-baseline --shard=1/2\n          else\n            node_modules/.bin/playwright test --project=local-chrome-baseline --shard=2/2\n          fi\n\n      - name: Run Playwright docs suite\n        if: matrix.suite == 'docs'\n        timeout-minutes: 20\n        env:\n          E2E_SELECTED_PROJECTS: docs-baseline\n        run: |\n          DOCS_OUT_DIR=test-results/docs \\\n          DOCS_IMG_OUT_DIR=test-results/docs/images \\\n          node_modules/.bin/playwright test --project=docs-baseline \\\n            --reporter=github,dot,./tests/support/reporters/documentation-reporter.ts\n\n      - name: Collect Docker logs\n        if: always()\n        run: |\n          compose() {\n            if [ -x node_modules/.bin/dotenv ]; then\n              node_modules/.bin/dotenv -c dev -- docker compose \"$@\"\n            else\n              docker compose \"$@\"\n            fi\n          }\n          compose_timeout() {\n            if [ -x node_modules/.bin/dotenv ]; then\n              timeout 90s node_modules/.bin/dotenv -c dev -- docker compose \"$@\"\n            else\n              timeout 90s docker compose \"$@\"\n            fi\n          }\n          mkdir -p test-results/docker-logs\n          compose_timeout logs --no-color > test-results/docker-logs/docker-compose.log || true\n          evorto_container_id=\"$(compose_timeout ps -q evorto || true)\"\n          if [ -n \"${evorto_container_id}\" ]; then\n            timeout 30s docker cp \"${evorto_container_id}:/app/logs/server.log\" test-results/docker-logs/server.log || true\n          fi\n\n      - name: Stop Docker stack\n        if: always()\n        timeout-minutes: 10\n        run: bash helpers/testing/ci-stop-docker-stack.sh\n\n      - name: Prune expired Neon branches after E2E\n        if: always()\n        timeout-minutes: 5\n        run: bash helpers/testing/ci-prune-neon-local-branches.sh\n\n      - name: Upload Playwright test results\n        if: always()\n        uses: actions/upload-artifact@v4\n        with:\n          name: playwright-test-results-${{ matrix.suite }}\n          path: |\n            test-results/**\n            playwright-report/**\n          if-no-files-found: ignore\n          retention-days: 7\n\n      - name: Upload generated docs\n        if: always() && matrix.suite == 'docs'\n        uses: actions/upload-artifact@v4\n        with:\n          name: e2e-docs\n          path: test-results/docs/**\n          if-no-files-found: ignore\n          retention-days: 14\n#!/usr/bin/env bash\nset -euo pipefail\n\nmode=\"${CI_DEPENDENCY_INSTALL_MODE:-offline-required}\"\nbun_cache_dir=\"${BUN_PACKAGE_CACHE_DIR:-${HOME}/.bun/install/cache}\"\npackage_cache_hit=\"${BUN_PACKAGE_CACHE_HIT:-false}\"\ndependency_tree_cache_hit=\"${BUN_DEPENDENCY_TREE_CACHE_HIT:-false}\"\nmissing_cache_message=\"${CI_DEPENDENCY_INSTALL_MISSING_CACHE_MESSAGE:-Bun dependency tree cache was not restored after the cache warmer. Refusing a registry install to avoid repeated Font Awesome package downloads.}\"\noffline_failure_message=\"${CI_DEPENDENCY_INSTALL_OFFLINE_FAILURE_MESSAGE:-Offline Bun install failed even though the package cache was restored. Refusing a registry install to avoid repeated Font Awesome package downloads.}\"\n\nif [ \"${mode}\" != \"warm\" ] && [ \"${mode}\" != \"offline-required\" ]; then\n  echo \"::error::Unsupported CI_DEPENDENCY_INSTALL_MODE=${mode}. Expected warm or offline-required.\"\n  exit 1\nfi\n\necho \"Bun package cache hit: ${package_cache_hit}\"\necho \"Bun dependency tree cache hit: ${dependency_tree_cache_hit}\"\n\nbun_package_cache_restored=\"false\"\nif [ -n \"$(find \"${bun_cache_dir}\" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)\" ]; then\n  bun_package_cache_restored=\"true\"\nfi\necho \"Bun package cache restored: ${bun_package_cache_restored}\"\n\nif [ \"${dependency_tree_cache_hit}\" = \"true\" ]; then\n  echo \"Bun dependency tree cache restored; skipping registry install.\"\n  exit 0\nfi\n\nif [ \"${bun_package_cache_restored}\" = \"true\" ]; then\n  if [ \"${mode}\" = \"warm\" ]; then\n    echo \"Bun dependency tree cache was not restored; installing offline from the warmed package cache before falling back to the serial cache warmer registry install.\"\n  else\n    echo \"Bun dependency tree cache was not restored; installing offline from the warmed package cache.\"\n  fi\n\n  if bun install --frozen-lockfile --offline --cache-dir \"${bun_cache_dir}\"; then\n    exit 0\n  fi\n\n  if [ \"${mode}\" = \"offline-required\" ]; then\n    echo \"::error::${offline_failure_message}\"\n    exit 1\n  fi\n\n  echo \"::warning::Offline Bun install failed even though the package cache was restored. Retrying once through the serial cache warmer registry install without clearing the package cache.\"\nfi\n\nif [ \"${mode}\" = \"offline-required\" ]; then\n  echo \"::error::${missing_cache_message}\"\n  exit 1\nfi\n\nif ! bun install --frozen-lockfile --cache-dir \"${bun_cache_dir}\"; then\n  echo \"::warning::Bun install failed. Retrying once without clearing the package cache.\"\n  bun install --frozen-lockfile --cache-dir \"${bun_cache_dir}\"\nfi\n#!/usr/bin/env bash\nset -euo pipefail\n\nif [ -f .npmrc ]; then\n  echo \"::error::Repository .npmrc is not supported; keep @fortawesome on the public npm registry through bunfig.toml and this CI user config.\"\n  exit 1\nfi\n\nnpm_config_userconfig=\"${RUNNER_TEMP:-/tmp}/npmrc-public-fontawesome\"\nprintf '%s\\n' '@fortawesome:registry=https://registry.npmjs.org/' > \"${npm_config_userconfig}\"\n\nif [ -n \"${GITHUB_ENV:-}\" ]; then\n  {\n    echo \"NPM_CONFIG_USERCONFIG=${npm_config_userconfig}\"\n    echo \"npm_config_userconfig=${npm_config_userconfig}\"\n  } >> \"${GITHUB_ENV}\"\nfi\n\nnode --input-type=module <<'NODE'\nimport { existsSync, readFileSync } from 'node:fs';\n\nconst privateRegistry = ['npm', 'fontawesome', 'com'].join('.');\nconst privatePackage = /@fortawesome\\/(?:duotone|pro|sharp)[^\"'\\s]*/u;\nconst files = ['package.json', 'bun.lock', 'bunfig.toml', 'Dockerfile'];\nlet failed = false;\n\nfor (const file of files) {\n  if (!existsSync(file)) {\n    continue;\n  }\n\n  const source = readFileSync(file, 'utf8');\n  if (source.includes(privateRegistry) || privatePackage.test(source)) {\n    console.error(\n      `::error file=${file}::Font Awesome must stay on free public npm packages in CI.`,\n    );\n    failed = true;\n  }\n}\n\nif (failed) {\n  process.exit(1);\n}\nNODE\n"}}
