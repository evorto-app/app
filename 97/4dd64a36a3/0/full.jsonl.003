e,\nsrc/app/profile/user-profile/user-profile.component.ts:475:        const updatedUser = profileUserAfterEdit(user, result);\nsrc/app/profile/user-profile/user-profile.component.ts:476:        this.profileUserOverride.set(updatedUser);\nsrc/app/core/not-allowed/not-allowed.component.ts:12:        Your account does not have permission to open this page.\nsrc/app/global-admin/tenant-edit/tenant-edit.component.html:68:            <mat-label>Stripe account ID</mat-label>\nsrc/app/global-admin/tenant-list/tenant-list.rows.ts:56:    label: 'Stripe account',\nsrc/app/global-admin/tenant-list/tenant-list.rows.spec.ts:31:      { label: 'Stripe account', value: 'Connected (acct_123)' },\nsrc/app/global-admin/tenant-list/tenant-list.rows.spec.ts:43:      'Stripe account',\nsrc/app/global-admin/tenant-list/tenant-list.rows.spec.ts:60:      label: 'Stripe account',\nsrc/app/global-admin/tenant-list/tenant-list.rows.spec.ts:67:  it('includes the connected account id when available for support lookup', () => {\nsrc/app/app.routes.server.ts:9:    path: 'create-account',\nsrc/app/app.routes.server.ts:25:    path: 'profile/**',\nsrc/app/admin/general-settings/general-settings.component.html:135:          <mat-label>Stripe account management</mat-label>\nsrc/app/admin/general-settings/general-settings.component.html:147:          <mat-hint>Controls who maintains the connected account.</mat-hint>\nsrc/app/admin/general-settings/general-settings.identity.spec.ts:19:      { label: 'Stripe account', value: 'Connected (acct_123)' },\nsrc/app/admin/general-settings/general-settings.identity.spec.ts:23:  it('shows a readable Stripe state when no account is configured', () => {\nsrc/app/admin/general-settings/general-settings.identity.spec.ts:31:      label: 'Stripe account',\nsrc/app/admin/general-settings/general-settings.identity.spec.ts:36:  it('treats an undefined Stripe account as not connected', () => {\nsrc/app/admin/general-settings/general-settings.identity.spec.ts:44:      label: