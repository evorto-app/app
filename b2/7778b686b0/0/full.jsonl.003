leted\"},{\"completedAt\":\"2026-06-05T09:53:20Z\",\"conclusion\":\"success\",\"name\":\"Post Set up Docker Buildx\",\"number\":26,\"startedAt\":\"2026-06-05T09:53:20Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:53:20Z\",\"conclusion\":\"success\",\"name\":\"Post Set up Bun dependency caches\",\"number\":27,\"startedAt\":\"2026-06-05T09:53:20Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:53:21Z\",\"conclusion\":\"success\",\"name\":\"Post Checkout repository\",\"number\":28,\"startedAt\":\"2026-06-05T09:53:20Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:53:21Z\",\"conclusion\":\"success\",\"name\":\"Complete job\",\"number\":29,\"startedAt\":\"2026-06-05T09:53:21Z\",\"status\":\"completed\"}],\"url\":\"https://github.com/evorto-app/app/actions/runs/27008018009/job/79704503004\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"databaseId\":79704769563,\"name\":\"Playwright E2E (docs)\",\"startedAt\":\"2026-06-05T09:53:25Z\",\"status\":\"queued\",\"steps\":[],\"url\":\"https://github.com/evorto-app/app/actions/runs/27008018009/job/79704769563\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"databaseId\":79704769571,\"name\":\"Playwright E2E (functional-2)\",\"startedAt\":\"2026-06-05T09:53:25Z\",\"status\":\"queued\",\"steps\":[],\"url\":\"https://github.com/evorto-app/app/actions/runs/27008018009/job/79704769571\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"databaseId\":79704769592,\"name\":\"Playwright E2E (functional-1)\",\"startedAt\":\"2026-06-05T09:53:28Z\",\"status\":\"in_progress\",\"steps\":[{\"completedAt\":\"2026-06-05T09:53:31Z\",\"conclusion\":\"success\",\"name\":\"Set up job\",\"number\":1,\"startedAt\":\"2026-06-05T09:53:29Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:53:33Z\",\"conclusion\":\"success\",\"name\":\"Checkout repository\",\"number\":2,\"startedAt\":\"2026-06-05T09:53:31Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:53:47Z\",\"conclusion\":\"success\",\"name\":\"Set up Bun dependency caches\",\"number\":3,\"startedAt\":\"2026-06-05T09:53:33Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:53:55Z\",\"conclusion\":\"success\",\"name\":\"Set up Docker Buildx\",\"number\":4,\"startedAt\":\"2026-06-05T09:53:47Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:54:07Z\",\"conclusion\":\"success\",\"name\":\"Restore Docker build cache\",\"number\":5,\"startedAt\":\"2026-06-05T09:53:55Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:54:08Z\",\"conclusion\":\"success\",\"name\":\"Restore Docker Bun cache mount\",\"number\":6,\"startedAt\":\"2026-06-05T09:54:07Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:54:08Z\",\"conclusion\":\"success\",\"name\":\"Require warmed Docker Bun cache mount\",\"number\":7,\"startedAt\":\"2026-06-05T09:54:08Z\",\"status\":\"completed\"},{\"completedAt\":\"2026-06-05T09:54:11Z\",\"conclusion\":\"success\",\"name\":\"Inject Docker Bun cache mount\",\"number\":8,\"startedAt\":\"2026-06-05T09:54:08Z\",\"status\":\"completed\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"name\":\"Restore Playwright browser cache\",\"number\":9,\"startedAt\":\"2026-06-05T09:54:11Z\",\"status\":\"in_progress\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"name\":\"Prepare Docker build cache directory\",\"number\":10,\"startedAt\":\"0001-01-01T00:00:00Z\",\"status\":\"pending\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"name\":\"Validate required configuration\",\"number\":11,\"startedAt\":\"0001-01-01T00:00:00Z\",\"status\":\"pending\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"name\":\"Prune expired Neon branches before E2E\",\"number\":12,\"startedAt\":\"0001-01-01T00:00:00Z\",\"status\":\"pending\"},{\"completedAt\":\"0001-01-01T00:00:00Z\",\"conclusion\":\"\",\"name\":\"Install dependencies\",\"number\":13,\"startedAt\":\"0001-0