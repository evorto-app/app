{"timestamp":"2026-07-19T17:52:49.806Z","type":"event_msg","payload":{"type":"token_count","info":{"total_token_usage":{"input_tokens":4534062416,"cached_input_tokens":4472902912,"cache_write_input_tokens":0,"output_tokens":5678816,"reasoning_output_tokens":2063225,"total_tokens":4539741232},"last_token_usage":{"input_tokens":202044,"cached_input_tokens":192256,"cache_write_input_tokens":0,"output_tokens":477,"reasoning_output_tokens":360,"total_tokens":202521},"model_context_window":258400},"rate_limits":{"limit_id":"codex","limit_name":null,"primary":null,"secondary":null,"credits":{"has_credits":true,"unlimited":true,"balance":null},"individual_limit":null,"spend_control_reached":null,"plan_type":"business","rate_limit_reached_type":null}}}
