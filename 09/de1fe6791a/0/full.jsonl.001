ocs:publish\": \"bun run env:runtime && DOCS_OUT_DIR=/Users/hedde/code/evorto-pages/apps/documentation/src/app/docs DOCS_IMG_OUT_DIR=/Users/hedde/code/evorto-pages/apps/documentation/public/docs dotenv -c dev -- playwright test --project=docs-baseline\",\n    \"test:e2e:install\": \"playwright install\",\n    \"test:e2e:report\": \"playwright show-report\",\n    \"db:push\": \"bun run env:runtime && dotenv -c dev -- drizzle-kit push --force\",\n    \"db:studio\": \"bun run env:runtime && dotenv -c dev -- drizzle-kit studio\",\n    \"db:reset\": \"bun run env:runtime && dotenv -c dev -- drizzle-kit push --force && dotenv -c dev -- bun helpers/database.ts\",\n    \"db:cleanup:neon-local\": \"bun run env:runtime && dotenv -c dev -- bun helpers/testing/delete-neon-local-branches.ts\",\n    \"neon:cleanup\": \"bun run db:cleanup:neon-local\",\n    \"neon:cleanup:dry-run\": \"bun run db:cleanup:neon-local -- --dry-run\",\n    \"docker:check\": \"bun run env:runtime && dotenv -c dev -- bun helpers/testing/runtime-preflight.ts docker\",\n    \"docker:bootstrap\": \"bun run env:bootstrap && dotenv -c dev -- bun helpers/testing/runtime-preflight.ts docker\",\n    \"docker:clean-stale\": \"bun run env:runtime && dotenv -c dev -- bun helpers/testing/remove-stale-compose-containers.ts\",\n    \"docker:ps\": \"bun run env:runtime && dotenv -c dev -- docker compose ps\",\n    \"docker:stop\": \"bun run env:runtime && dotenv -c dev -- bash helpers/testing/ci-stop-docker-stack.sh\",\n    \"docker:reset\": \"bun run docker:check && dotenv -c dev -- docker compose down\",\n    \"docker:resume\": \"bun run docker:check && dotenv -c dev -- docker compose up --no-recreate -d\",\n    \"docker:start\": \"bun run docker:reset && dotenv -c dev -- docker compose up --build -d\",\n    \"docker:start:watch\": \"bun run docker:reset && dotenv -c dev -- docker compose up --build -w\",\n    \"docker:start:foreground\": \"bun run docker:reset && dotenv -c dev -- docker compose up --build\",\n    \"docker:webserver\": \"bun run docker:check && dotenv -c dev -- docker compose rm --force && dotenv -c dev -- docker compose up --build\",\n    \"db:migrate\": \"bun migration/index.ts\",\n    \"deps:update:angular\": \"bunx --bun ng update @angular/cli @angular/cdk @angular/core @angular/material angular-eslint --allow-dirty\",\n    \"deps:update:drizzle\": \"bun add drizzle-orm@rc && bun add -D drizzle-seed@rc drizzle-kit@rc\",\n    \"ops:stripe:listen\": \"stripe listen --forward-to http://localhost:4200/webhooks/stripe\",\n    \"ops:sentry:sourcemaps\": \"sentry-cli sourcemaps inject --org lukas-heddendorp --project evorto ./dist && sentry-cli sourcemaps upload --org lukas-heddendorp --project evorto ./dist\",\n    \"ui:theme:generate\": \"bunx --bun ng generate @angular/material:theme-color --include-high-contrast --primary-color=#0891b2 --interactive=false --directory=src/ --force\",\n    \"ui:theme:generate:esn\": \"bunx --bun ng generate @angular/material:theme-color --include-high-contrast --primary-color=#00aeef --secondary-color=#ec008c --tertiary-color=#7ac143 --interactive=false --directory=src/_esn --force\",\n    \"test:cleanup:receipt-images\": \"bun helpers/cleanup-testing-receipt-images.ts\",\n    \"test:cleanup:receipt-images:dry-run\": \"bun helpers/cleanup-testing-receipt-images.ts --dry-run\"\n  },\n  \"private\": true,\n  \"dependencies\": {\n    \"@angular/animations\": \"^21.2.10\",\n    \"@angular/cdk\": \"21.2.8\",\n    \"@angular/common\": \"^21.2.10\",\n    \"@angular/compiler\": \"^21.2.10\",\n    \"@angular/core\": \"^21.2.10\",\n    \"@angular/forms\": \"^21.2.10\",\n    \"@angular/material\": \"21.2.8\",\n    \"@angular/material-luxon-adapter\": \"^21.2.8\",\n    \"@angular/platform-browser\": \"^21.2.10\",\n    \"@angular/platform-server\": \"^21.2.10\",\n    \"@angular/router\": \"^21.2.10\",\n    \"@angular/ssr\": \"^21.2.8\",\n    \"@auth0/auth0-server-js\": \"^1.4.0\",\n    \"@effect/opentelemetry\": \"4.0.0-beta.60\",\n    \"@effect/platform-bun\": \"4.0.0-beta.60\",\n    \"@effect/sql-pg\": \"4.0.0-beta.60\",\n    \"@fortawesome/angular-fontawesome\": \"4.0.0\",\n        with:\n          builder: ${{ steps.setup-buildx.outputs.name }}\n          cache-map: |\n            {\n              \"${{ env.BUILDKIT_BUN_CACHE_DIR }}\": {\n                \"target\": \"/home/bun/.bun/install/cache\",\n                \"id\": \"bun-install-cache\"\n              }\n            }\n          skip-extraction: true\n\n      - name: Restore Playwright browser cache\n        uses: actions/cache/restore@v4\n        with:\n          path: ~/.cache/ms-playwright\n          key: ${{ runner.os }}-playwright-1.59.1-chromium\n          restore-keys: |\n            ${{ runner.os }}-playwright-1.59.1-\n\n      - name: Prepare Docker build cache directory\n        run: mkdir -p \"${DOCKER_BUILD_CACHE_DIR}\"\n\n      - name: Validate required configuration\n        run: bash helpers/testing/validate-ci-runtime-env.sh e2e\n\n      - name: Prune expired Neon branches before E2E\n        run: bash helpers/testing/ci-prune-neon-local-branches.sh\n\n      - name: Install dependencies\n        env:\n          BUN_DEPENDENCY_TREE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-hit }}\n          BUN_PACKAGE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.package-cache-hit }}\n          CI_DEPENDENCY_INSTALL_MISSING_CACHE_MESSAGE: Bun dependency tree cache was not restored after warm-ci-caches. Refusing a parallel registry install to avoid repeated Font Awesome package downloads.\n          CI_DEPENDENCY_INSTALL_MODE: offline-required\n        run: bash helpers/testing/install-ci-dependencies.sh\n\n      - name: Save Bun dependency tree from package cache\n        if: steps.bun-dependency-caches.outputs.dependency-tree-cache-hit != 'true'\n        uses: actions/cache/save@v4\n        with:\n          path: node_modules\n          key: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-primary-key }}\n\n      - name: Install Playwright browsers\n        run: bunx playwright install --with-deps chromium\n\n      - name: Prepare Neon Local metadata directory\n        run: |\n          rm -rf \"${NEON_LOCAL_METADATA_DIR}\"\n          mkdir -p \"${NEON_LOCAL_METADATA_DIR}\"\n          chmod 0777 \"${NEON_LOCAL_METADATA_DIR}\"\n\n      - name: Start Docker stack for E2E\n        timeout-minutes: 25\n        run: bash helpers/testing/ci-start-docker-stack.sh\n\n      - name: Confirm Neon branch expiration\n        run: bun helpers/testing/set-neon-local-branch-expiration.ts\n\n      - name: Record Neon Local branch metadata\n        if: always()\nauthentication.setup.ts\ndatabase.setup.ts\nmcp-browser-authenticated.seed.ts\n"}}
