(github )?actions|supply[ -]?chain|supply[ -]?chain[ -]?policy|action.*commit.*hash|github.*pin\\\" \\\\\\n  .github . || true\\n\\necho \\\"\\\"\\necho \\\"=== Search workflows for any uses:@\\u003chex\\u003e pins (short + targeted) ===\\\"\\nrg -n --hidden --glob '.github/workflows/*.{yml,yaml}' \\\\\\n  'uses:\\\\s*[^@]+@[\\\\da-fA-F]{7,40}\\\\b' \\\\\\n  .github/workflows || true\\n```\\n\\nRepository: evorto-app/app\\n\\nLength of output: 50372\\n\\n---\\n\\n🏁 Script executed:\\n\\n```shell\\n#!/bin/bash\\nset -euo pipefail\\n\\necho \\\"=== List potential security/pinning policy docs at repo root ===\\\"\\nfd -a --hidden -t f -e md -e txt SECURITY* README* CONTRIBUTING* -x echo 2\\u003e/dev/null || true\\nfd -a --hidden -t f -e md -e txt -t f -E '**/repos/**' -E '**/node_modules/**' -E '**/dist/**' -E '**/build/**' -E '**/coverage/**' \\\\\\n  -e SECURITY* -e POLICY* -e SECURITY.md -e '.github' . \\u003e/dev/null 2\\u003e\\u00261 || true\\n\\necho \\\"\\\"\\necho \\\"=== Candidate policy doc file paths (root + .github only) ===\\\"\\nfd -a --hidden -t f -e md -e txt -E '**/repos/**' -E '**/node_modules/**' -E '**/dist/**' -E '**/build/**' -E '**/coverage/**' \\\\\\n  SECURITY* .github README* POLICY* CODEOWNERS* SECURITY.md || true\\n\\necho \\\"\\\"\\necho \\\"=== Search only within root/.github docs for pinned-action/supply-chain policy keywords ===\\\"\\nrg -n --hidden --glob '!**/repos/**' --glob '!**/node_modules/**' --glob '!**/dist/**' --glob '!**/build/**' --glob '!**/coverage/**' \\\\\\n  -i \\\"zizmor|pinned action|pinned github action|pin(ned)? (github )?actions|supply[ -]?chain.*policy|action.*commit.*hash|github.*pin\\\" \\\\\\n  .github docs README* SECURITY* POLICY* CODEOWNERS* || true\\n```\\n\\nRepository: evorto-app/app\\n\\nLength of output: 718\\n\\n---\\n\\n🏁 Script executed:\\n\\n```shell\\n#!/bin/bash\\nset -euo pipefail\\n\\necho \\\"=== .github/workflows: uses pinned to commit SHAs? (short or full) ===\\\"\\nrg -n --hidden --glob '.git