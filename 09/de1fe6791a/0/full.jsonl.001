)\n    runs-on: ubuntu-latest\n    needs: warm-ci-caches\n    timeout-minutes: 60\n    strategy:\n      fail-fast: false\n      max-parallel: 1\n      matrix:\n        suite: [functional-1, functional-2, docs]\n    env:\n      CI: true\n      APP_HOST_PORT: 4200\n      BASE_URL: http://localhost:4200\n      BUILDKIT_BUN_CACHE_DIR: buildkit-bun-cache\n      APP_READY_PATH: /robots.txt\n      COMPOSE_PROJECT_NAME: evorto-ci\n      DELETE_BRANCH: true\n      DOCKER_BUILD_CACHE_DIR: /tmp/evorto-docker-build-cache\nname: E2E Baseline\n\non:\n  workflow_dispatch:\n  push:\n    branches: [main, develop]\n  pull_request:\n\nconcurrency:\n  group: e2e-${{ github.ref }}\n  cancel-in-progress: true\n\nenv:\n  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true\n\njobs:\n  warm-ci-caches:\n    name: Warm CI dependency caches\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    env:\n      BUILDKIT_BUN_CACHE_DIR: buildkit-bun-cache\n      DELETE_BRANCH: true\n      DOCKER_BUILD_CACHE_DIR: /tmp/evorto-docker-build-cache\n      NEON_API_KEY: ${{ secrets.NEON_API_KEY }}\n      NEON_LOCAL_BRANCH_TTL_HOURS: 2\n      NEON_PROJECT_ID: ${{ vars.NEON_PROJECT_ID }}\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n\n      - name: Set up Bun dependency caches\n        id: bun-dependency-caches\n        uses: ./.github/actions/setup-bun-dependency-caches\n\n      - name: Prune expired Neon branches before cache installs\n        run: bash helpers/testing/ci-prune-neon-local-branches.sh\n\n      - name: Pre-pull BuildKit image\n        run: bash helpers/testing/ci-pull-buildkit-image.sh\n\n      - name: Set up Docker Buildx\n        id: setup-buildx\n        uses: docker/setup-buildx-action@v4\n        with:\n          version: latest\n\n      - name: Restore Docker build cache\n        uses: actions/cache@v4\n        with:\n          path: ${{ env.DOCKER_BUILD_CACHE_DIR }}\n          key: ${{ runner.os }}-docker-build-bun-1.3.11-${{ hashFiles('Dockerfile', 'docker-compose.yml', '.github/docker-compose.build-cache.yml', 'package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-docker-build-bun-1.3.11-\n\n      - name: Restore Docker Bun cache mount\n        id: docker-bun-cache-mount\n        uses: actions/cache@v4\n        with:\n          path: ${{ env.BUILDKIT_BUN_CACHE_DIR }}\n"}}
