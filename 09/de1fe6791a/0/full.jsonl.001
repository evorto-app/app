{"timestamp":"2026-06-09T08:57:26.192Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_H5itSSTnjrJ5R01w4KKfIKAs","output":"Chunk ID: 16ff37\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 931\nOutput:\n    # Set the permissions to the lowest permissions possible needed for your steps.\n    # Copilot will be given its own token for its operations.\n    permissions:\n      # If you want to clone the repository as part of your setup steps, for example to install dependencies, you'll need the `contents: read` permission. If you don't clone the repository in your setup steps, Copilot will do this for you automatically after the steps complete.\n      contents: read\n\n    # You can define any steps you want, and they will run before the agent starts.\n    # If you do not check out your code, Copilot will do this for you.\n    steps:\n      - name: Checkout code\n        uses: actions/checkout@v4\n\n      - name: Set up Bun\n        uses: oven-sh/setup-bun@v2\n        with:\n          bun-version: \"1.3.11\"\n\n<<<<<<< HEAD\n      - name: Enforce public Font Awesome dependencies\n=======\n      - name: Prepare public Font Awesome registry\n>>>>>>> 378f53161f (Centralize Font Awesome CI guard)\n        run: bash helpers/testing/prepare-public-fontawesome-ci.sh\n\n      - name: Restore Bun package cache\n        id: bun-package-cache\n        uses: actions/cache/restore@v4\n        with:\n          path: ~/.bun/install/cache\n          key: ${{ runner.os }}-bun-1.3.11-${{ hashFiles('package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-bun-1.3.11-\n\n      - name: Restore Bun dependency tree\n        id: bun-dependency-tree-cache\n        uses: actions/cache/restore@v4\n        with:\n          path: node_modules\n          key: ${{ runner.os }}-bun-node-modules-1.3.11-${{ hashFiles('package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-bun-node-modules-1.3.11-\n\n      - name: Install dependencies\n        run: |\n          echo \"Bun package cache hit: ${{ steps.bun-package-cache.outputs.cache-hit }}\"\n          echo \"Bun dependency tree cache hit: ${{ steps.bun-dependency-tree-cache.outputs.cache-hit }}\"\n          bun_package_cache_restored=\"false\"\n          if [ -n \"$(find \"${HOME}/.bun/install/cache\" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)\" ]; then\n            bun_package_cache_restored=\"true\"\n          fi\n          echo \"Bun package cache restored: ${bun_package_cache_restored}\"\n          if [ \"${{ steps.bun-dependency-tree-cache.outputs.cache-hit }}\" = \"true\" ]; then\n            echo \"Bun dependency tree cache restored; skipping registry install.\"\n            exit 0\n          fi\n          if [ \"${bun_package_cache_restored}\" = \"true\" ]; then\n            echo \"Bun dependency tree cache was not restored; installing offline from the warmed package cache.\"\n            if bun install --frozen-lockfile --offline --cache-dir ~/.bun/install/cache; then\n              exit 0\n            fi\n            echo \"::warning::Offline Bun install failed even though the package cache was restored. Retrying once through the Copilot setup registry install.\"\n          fi\n          bun install --frozen-lockfile --cache-dir ~/.bun/install/cache\n\n      - name: Save Bun dependency tree from package cache\n        if: steps.bun-dependency-tree-cache.outputs.cache-hit != 'true'\n        uses: actions/cache/save@v4\n        with:\n          path: node_modules\n          key: ${{ steps.bun-dependency-tree-cache.outputs.cache-primary-key }}\n\n      - name: Restore Playwright browser cache\n        uses: actions/cache@v4\n        with:\n          path: ~/.cache/ms-playwright\n          key: ${{ runner.os }}-playwright-1.59.1-chromium\n          restore-keys: |\n            ${{ runner.os }}-playwright-1.59.1-\n\n      - name: Install Playwright browsers\n        run: node_modules/.bin/playwright install --with-deps\n"}}
