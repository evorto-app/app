) {\n    if (rejectInvalidUrl) {\n      throw new InvalidDiscountProviderConfigError();\n    }\n    return validationMode;\n  }\n\n  return { buyEsnCardUrl: normalizedBuyUrl, ...validationMode };\n};\n"}}
