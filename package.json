{
  "name": "evorto",
  "version": "0.0.0",
  "scripts": {
    "env:runtime": "bun helpers/testing/runtime-environment.ts",
    "dev:ng": "bunx --bun ng",
    "dev:start": "bunx --bun ng serve",
    "build:app": "NG_BUILD_PARTIAL_SSR=1 bunx --bun ng build",
    "build:watch": "NG_BUILD_PARTIAL_SSR=1 bunx --bun ng build --watch --configuration development",
    "test:unit": "bunx --bun ng test",
    "test:unit:server": "bunx vitest run --config vitest.config.ts",
    "test:unit:server:watch": "bunx vitest --config vitest.config.ts",
    "lint:check": "bunx --bun ng lint",
    "lint:fix": "bunx --bun ng lint --fix",
    "format:write": "prettier --write .",
    "test:e2e": "dotenv -c dev -- playwright test --project=local-chrome-baseline",
    "test:e2e:ui": "dotenv -c dev -- playwright test --ui",
    "test:e2e:docs": "dotenv -c dev -- playwright test --project=docs-baseline",
    "test:e2e:report": "playwright show-report",
    "db:push": "dotenv -c dev -- drizzle-kit push --force",
    "db:studio": "dotenv -c dev -- drizzle-kit studio",
    "db:setup": "dotenv -c dev -- drizzle-kit push --force && dotenv -c dev -- bun helpers/database.ts",
    "db:reset": "bun run db:setup",
    "docker:stop": "dotenv -c dev -- docker compose down",
    "docker:start": "dotenv -c dev -- docker compose down && dotenv -c dev -- docker compose up --build -d",
    "docker:start:watch": "dotenv -c dev -- docker compose down && dotenv -c dev -- docker compose up --build -w",
    "docker:start:foreground": "dotenv -c dev -- docker compose down && dotenv -c dev -- docker compose up --build",
    "db:migrate": "bun migration/index.ts",
    "deps:update:angular": "bunx --bun ng update @angular/cli @angular/cdk @angular/core @angular/material angular-eslint --allow-dirty",
    "deps:update:drizzle": "bun add drizzle-orm@beta && bun add -D drizzle-seed@beta drizzle-kit@beta",
    "ops:stripe:listen": "stripe listen --forward-to http://localhost:4200/webhooks/stripe",
    "ops:sentry:sourcemaps": "sentry-cli sourcemaps inject --org lukas-heddendorp --project evorto ./dist && sentry-cli sourcemaps upload --org lukas-heddendorp --project evorto ./dist",
    "ui:theme:generate": "bunx --bun ng generate @angular/material:theme-color --include-high-contrast --primary-color=#0891b2 --interactive=false --directory=src/ --force",
    "ui:theme:generate:esn": "bunx --bun ng generate @angular/material:theme-color --include-high-contrast --primary-color=#00aeef --secondary-color=#ec008c --tertiary-color=#7ac143 --interactive=false --directory=src/_esn --force",
    "test:cleanup:receipt-images": "bun helpers/cleanup-testing-receipt-images.ts",
    "test:cleanup:receipt-images:dry-run": "bun helpers/cleanup-testing-receipt-images.ts --dry-run"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/material": "21.2.7",
    "@angular/material-luxon-adapter": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-server": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/ssr": "^21.2.7",
    "@auth0/auth0-server-js": "^1.4.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/rpc": "^0.75.0",
    "@effect/sql-pg": "0.52.1",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/duotone-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@heddendorp/effect-angular-query": "0.1.3",
    "@heddendorp/effect-platform-angular": "^0.0.8",
    "@material/material-color-utilities": "0.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@sentry/angular": "^10.49.0",
    "@sentry/bun": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/angular-query-experimental": "5.99.1",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-file-handler": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "cloudflare": "^5.2.0",
    "consola": "^3.4.2",
    "drizzle-orm": "^1.0.0-beta.22",
    "effect": "^3.21.1",
    "es-toolkit": "^1.45.1",
    "html-to-text": "^9.0.5",
    "inter-ui": "^4.1.1",
    "luxon": "^3.7.2",
    "marked": "^17.0.4",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.2",
    "sanitize-html": "^2.17.3",
    "skia-canvas": "^3.0.8",
    "stripe": "^20.4.1",
    "tslib": "^2.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@axe-core/playwright": "^4.11.2",
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "^0.29.0",
    "@eslint/js": "^10.0.1",
    "@ngneat/falso": "^8.0.2",
    "@playwright/test": "1.59.1",
    "@sentry/cli": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.99.1",
    "@types/bun": "^1.3.12",
    "@types/dom-speech-recognition": "^0.0.9",
    "@types/google.maps": "^3.64.0",
    "@types/html-to-text": "^9.0.4",
    "@types/jasmine": "^6.0.0",
    "@types/luxon": "^3.7.1",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "angular-eslint": "21.3.1",
    "auth0": "^5.7.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^1.0.0-beta.22",
    "drizzle-seed": "^1.0.0-beta.22",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright-ng-schematics": "21.0.10",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "patchedDependencies": {
    "@material/material-color-utilities@0.4.0": "patches/@material-material-color-utilities-npm-0.4.0-9d48ca70b8.patch"
  },
  "packageManager": "bun@1.3.11"
}
