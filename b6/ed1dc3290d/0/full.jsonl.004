const pool = new Pool(\n    createNodePgPoolConfig({\n      caCertificate,\n      databaseUrl,\n    }),\n  );\n\n  return {\n    database: drizzle<typeof relations>({\n      client: pool,\n      relations,\n    }),\n    pool,\n  };\n};\n\nexport type ScriptDatabaseClient = ReturnType<\n  typeof createDatabaseClient\n>['database'];\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:77:\toverride transaction<A, E, R>(\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:78:\t\ttransaction: (\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:84:\t\treturn this.client.withTransaction(Effect.gen({ self: this }, function*() {\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:91:\t\t\treturn yield* transaction(tx);\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:102:\toverride transaction<A, E, R>(\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:103:\t\ttransaction: (\nrepos/drizzle/drizzle-orm/src/effect-postgres/session.ts:107:\t\treturn this.session.transaction(transaction);\nrepos/drizzle/drizzle-kit/src/index.ts:67: * that do not support multiple DDL alternation statements in one transaction(MySQL, SQLite, SingleStore) and\nrepos/drizzle/drizzle-kit/src/index.ts:330: * that do not support multiple DDL alternation statements in one transaction(MySQL, SQLite, SingleStore) and\nrepos/drizzle/integration-tests/tests/singlestore/singlestore.rels.test.ts:927:test('[Find Many] Get users with posts in transaction', async () => {\nrepos/drizzle/integration-tests/tests/singlestore/singlestore.rels.test.ts:941:\tawait db.transaction(async (tx) => {\nrepos/drizzle/integration-tests/tests/singlestore/singlestore.rels.test.ts:994:test('[Find Many] Get users with posts in rollbacked transaction', async () => {\nrepos/drizzle/integration-tests/tests/singlestore/singlestore.rels.test.ts:1008:\tawait expect(db.transaction(async (tx) => {\nrepos/drizzle/drizzle-orm/type-tests/sqlite/sync-tx-no-promise.ts:6:syncDb.transaction(async (tx) => 