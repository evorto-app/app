# Copy the variables you need into .env and fill in local developer secrets.
# Do not put real secret values in this file.

# Font Awesome package registry access for premium and brand icon packages.
FONT_AWESOME_TOKEN=

# Neon Local branch creation and project selection.
NEON_API_KEY=
NEON_PROJECT_ID=
# Required by CI/provider workflows so their disposable branch parent is
# explicit; local Docker may use the Neon project's configured default.
PARENT_BRANCH_ID=

# Auth0 application configuration.
CLIENT_ID=
CLIENT_SECRET=
ISSUER_BASE_URL=

# Required only for credential-backed account-management integration journeys.
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=

# Required for the six stable non-production accounts authenticated by the
# Playwright setup. Store rotated values only in ignored local .env files. Do
# not provision CI until the trusted-workflow or disposable-account custody
# decision in tests/README.md is implemented; never commit or print them.
E2E_DEFAULT_USER_PASSWORD=
E2E_ADMIN_USER_PASSWORD=
E2E_GLOBAL_ADMIN_USER_PASSWORD=
E2E_REGULAR_USER_PASSWORD=
E2E_ORGANIZER_USER_PASSWORD=
E2E_EMPTY_USER_PASSWORD=

# Optional local e2e fallback for Auth0 tenants where the post-login action does
# not emit the global-admin app metadata claim into the session.
E2E_GLOBAL_ADMIN_AUTH0_IDS=

# Optional for local Playwright discovery, but mandatory in the protected
# esncard-release-certification GitHub environment. Use only approved
# non-production ESNcard identities: one active and one permanently expired.
# Never commit or print either value.
E2E_LIVE_ESN_CARD_IDENTIFIER=
E2E_LIVE_ESN_CARD_EXPIRED_IDENTIFIER=

# Required for production location search and the credential-backed Google
# Maps integration journey. Enable billing, Maps JavaScript API, and Places API
# (New), and restrict the browser key to the local and production origins that
# use it.
PUBLIC_GOOGLE_MAPS_API_KEY=

# Absolute path to a clean, current evorto-pages checkout containing
# apps/documentation-page and tools/docs/sync-generated-docs.mjs. Required only
# by the intentional generated-documentation publication command.
EVORTO_PAGES_ROOT=

# Application session signing secret.
SECRET=

# Stripe API access and connected account used by seeded paid flows.
STRIPE_API_KEY=
STRIPE_TEST_ACCOUNT_ID=
