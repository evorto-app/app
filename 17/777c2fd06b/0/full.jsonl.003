{"timestamp":"2026-06-05T09:57:41.789Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_SvRFEanK9h2zLOb7edLyqGpL","output":"Chunk ID: 96eb05\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 482\nOutput:\nname: Set up Bun dependency caches\ndescription: Set up Bun, force public Font Awesome packages, and restore dependency caches.\n\ninputs:\n  bun-version:\n    description: Bun version to install.\n    required: false\n    default: \"1.3.11\"\n\noutputs:\n  dependency-tree-cache-hit:\n    description: Whether the node_modules cache was restored.\n    value: ${{ steps.bun-dependency-tree-cache.outputs.cache-hit }}\n  dependency-tree-cache-primary-key:\n    description: Primary key for saving the node_modules cache.\n    value: ${{ steps.bun-dependency-tree-cache.outputs.cache-primary-key }}\n  package-cache-hit:\n    description: Whether the Bun package cache was restored.\n    value: ${{ steps.bun-package-cache.outputs.cache-hit }}\n  package-cache-primary-key:\n    description: Primary key for saving the Bun package cache.\n    value: ${{ steps.bun-package-cache.outputs.cache-primary-key }}\n\nruns:\n  using: composite\n  steps:\n    - name: Set up Bun\n      uses: oven-sh/setup-bun@v2\n      with:\n        bun-version: ${{ inputs.bun-version }}\n\n    - name: Prepare public Font Awesome registry\n      shell: bash\n      run: bash helpers/testing/prepare-public-fontawesome-ci.sh\n\n    - name: Restore Bun package cache\n      id: bun-package-cache\n      uses: actions/cache/restore@v4\n      with:\n        path: ~/.bun/install/cache\n        key: ${{ runner.os }}-bun-${{ inputs.bun-version }}-${{ hashFiles('package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n        restore-keys: |\n          ${{ runner.os }}-bun-${{ inputs.bun-version }}-\n\n    - name: Restore Bun dependency tree\n      id: bun-dependency-tree-cache\n      uses: actions/cache/restore@v4\n      with:\n        path: node_modules\n        key: ${{ runner.os }}-bun-node-modules-${{ inputs.bun-version }}-${{ hashFiles('package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n        restore-keys: |\n          ${{ runner.os }}-bun-node-modules-${{ inputs.bun-version }}-\n"}}
