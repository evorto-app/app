dSpots: 0,\n  1034\t        waitlistSpots: 0,\n  1035\t      })\n  1036\t      .where(eq(schema.eventRegistrationOptions.id, paidOptionId));\n  1037\t    await database\n  1038\t      .update(schema.eventInstances)\n  1039\t      .set({\n  1040\t        end: serverFutureEventEnd,\n  1041\t        start: serverFutureEventStart,\n  1042\t      })\n  1043\t      .where(eq(schema.eventInstances.id, paidEvent.id));\n  1044\t\n  1045\t    await page.goto('.');\n  1046\t    await testInfo.attach('markdown', {\n  1047\t      body: `\n  1048\t  To register for a paid event, you have to pay the registration fee.`,\n  1049\t    });\n  1050\t    await gotoEventDetail(page, paidEvent.id);\n  1051\t    await waitForRegistrationStatus(page);\n  1052\t    const payButton = page.getByRole('button', { name: /Pay/i }).first();\n  1053\t    await takeScreenshot(\n  1054\t      testInfo,\n  1055\t      registrationOptionCard(page, 'Pay'),\n  1056\t      page,\n  1057\t      'Paid event registration options before starting Stripe Checkout',\n  1058\t    );\n  1059\t    await testInfo.attach('markdown', {\n  1060\t      body: `\n  1061\t  By clicking the **Pay and register** button, you are starting the payment process.\n  1062\t  Paid guest spots are included in the Stripe Checkout quantity and reserve the matching capacity while payment is pending.\n  1063\t  Afterwards, you can either finish the registration by paying or cancel your payment and registration in case you changed your mind. Cancelling a pending payment registration releases every selected buyer and guest spot and expires the pending checkout when possible.`,\n  1064\t    });\n  1065\t    await takeScreenshot(\n  1066\t      testInfo,\n  1067\t      payButton,\n  1068\t      page,\n  1069\t      'Paid registration button before the pending checkout recovery state',\n  1070\t    );\n   320\t                            registrationOption.id\n   321\t                          )\n   322\t                        \"\n   323\t   