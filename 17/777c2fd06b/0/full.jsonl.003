{"timestamp":"2026-06-05T09:57:41.830Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_pYdsoSspnQ1Kmt6sr0U8VII6","output":"Chunk ID: 85b59b\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 3140\nOutput:\nname: E2E Baseline\n\non:\n  workflow_dispatch:\n  push:\n    branches: [main, develop]\n    paths-ignore:\n      - \"**/*.md\"\n      - \".changeset/**\"\n  pull_request:\n    paths-ignore:\n      - \"**/*.md\"\n      - \".changeset/**\"\n\nconcurrency:\n  group: e2e-${{ github.ref }}\n  cancel-in-progress: true\n\nenv:\n  COMPOSE_DOCKER_CLI_BUILD: 1\n  DOCKER_BUILDKIT: 1\n  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true\n  PLAYWRIGHT_BROWSERS_PATH: /home/runner/.cache/ms-playwright\n\njobs:\n  warm-ci-caches:\n    name: Warm CI dependency caches\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    env:\n      BUILDKIT_BUN_CACHE_DIR: buildkit-bun-cache\n      DOCKER_BUILD_CACHE_DIR: /tmp/evorto-docker-build-cache\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n\n      - name: Set up Bun dependency caches\n        id: bun-dependency-caches\n        uses: ./.github/actions/setup-bun-dependency-caches\n\n      - name: Set up Docker Buildx\n        id: setup-buildx\n        uses: docker/setup-buildx-action@v4\n        with:\n          version: latest\n\n      - name: Restore Docker build cache\n        uses: actions/cache@v4\n        with:\n          path: ${{ env.DOCKER_BUILD_CACHE_DIR }}\n          key: ${{ runner.os }}-docker-build-bun-1.3.11-${{ hashFiles('Dockerfile', 'docker-compose.yml', '.github/docker-compose.build-cache.yml', 'package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-docker-build-bun-1.3.11-\n\n      - name: Restore Docker Bun cache mount\n        id: docker-bun-cache-mount\n        uses: actions/cache@v4\n        with:\n          path: ${{ env.BUILDKIT_BUN_CACHE_DIR }}\n          key: ${{ runner.os }}-docker-bun-cache-mount-1.3.11-${{ hashFiles('package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-docker-bun-cache-mount-1.3.11-\n\n      - name: Inject Docker Bun cache mount\n        uses: reproducible-containers/buildkit-cache-dance@v3.4.0\n        with:\n          builder: ${{ steps.setup-buildx.outputs.name }}\n          cache-map: |\n            {\n              \"${{ env.BUILDKIT_BUN_CACHE_DIR }}\": {\n                \"target\": \"/home/bun/.bun/install/cache\",\n                \"id\": \"bun-install-cache\"\n              }\n            }\n          skip-extraction: ${{ steps.docker-bun-cache-mount.outputs.cache-hit }}\n\n      - name: Prepare Docker build cache directory\n        run: mkdir -p \"${DOCKER_BUILD_CACHE_DIR}\"\n\n      - name: Install dependencies\n        env:\n          BUN_DEPENDENCY_TREE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-hit }}\n          BUN_PACKAGE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.package-cache-hit }}\n          CI_DEPENDENCY_INSTALL_MODE: warm\n        run: bash helpers/testing/install-ci-dependencies.sh\n\n      - name: Save warmed Bun package cache\n        if: steps.bun-dependency-caches.outputs.package-cache-hit != 'true'\n        uses: actions/cache/save@v4\n        with:\n          path: ~/.bun/install/cache\n          key: ${{ steps.bun-dependency-caches.outputs.package-cache-primary-key }}\n\n      - name: Save warmed Bun dependency tree\n        if: steps.bun-dependency-caches.outputs.dependency-tree-cache-hit != 'true'\n        uses: actions/cache/save@v4\n        with:\n          path: node_modules\n          key: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-primary-key }}\n\n      - name: Restore Playwright browser cache\n        uses: actions/cache@v4\n        with:\n          path: ~/.cache/ms-playwright\n          key: ${{ runner.os }}-playwright-1.59.1-chromium\n          restore-keys: |\n            ${{ runner.os }}-playwright-1.59.1-\n\n      - name: Warm Playwright browser cache\n        run: node_modules/.bin/playwright install --with-deps chromium\n\n      - name: Warm Docker build cache\n        run: |\n          timeout 8m docker build \\\n            --target dependencies \\\n            --cache-from type=gha,scope=evorto-dependencies \\\n            --cache-to type=gha,scope=evorto-dependencies,mode=max \\\n            --progress=plain \\\n            .\n\n  e2e:\n    name: Playwright E2E (${{ matrix.suite }})\n    needs: warm-ci-caches\n    runs-on: ubuntu-latest\n    timeout-minutes: 60\n    strategy:\n      fail-fast: false\n      max-parallel: 1\n      matrix:\n        suite: [functional-1, functional-2, docs]\n    env:\n      CI: true\n      APP_HOST_PORT: 4200\n      BASE_URL: http://localhost:4200\n      APP_READY_PATH: /robots.txt\n      COMPOSE_PROJECT_NAME: evorto-ci\n      DELETE_BRANCH: true\n      NEON_DATABASE_NAME: appdb\n      NEON_LOCAL_BRANCH_TTL_HOURS: 2\n      NEON_LOCAL_HOST_PORT: 55432\n      NEON_LOCAL_METADATA_DIR: /tmp/neon-local-metadata\n      NEON_LOCAL_METADATA_WAIT_SECONDS: 180\n      NEON_LOCAL_PROXY: true\n      NO_WEBSERVER: true\n      DATABASE_URL: postgresql://neon:npg@localhost:55432/appdb?sslmode=require\n      NEON_API_KEY: ${{ secrets.NEON_API_KEY }}\n      NEON_PROJECT_ID: ${{ vars.NEON_PROJECT_ID }}\n      PARENT_BRANCH_ID: ${{ secrets.PARENT_BRANCH_ID }}\n      CLIENT_ID: ${{ secrets.CLIENT_ID }}\n      CLIENT_SECRET: ${{ secrets.CLIENT_SECRET }}\n      ISSUER_BASE_URL: ${{ secrets.ISSUER_BASE_URL || vars.ISSUER_BASE_URL || 'https://tumi-dev.eu.auth0.com' }}\n      SECRET: ${{ secrets.SECRET || vars.SECRET || 'ci-localtestingsecret' }}\n      STRIPE_API_KEY: ${{ secrets.STRIPE_API_KEY }}\n      STRIPE_TEST_ACCOUNT_ID: ${{ secrets.STRIPE_TEST_ACCOUNT_ID || vars.STRIPE_TEST_ACCOUNT_ID }}\n      STRIPE_WEBHOOK_SECRET: ${{ secrets.STRIPE_WEBHOOK_SECRET }}\n      S3_ACCESS_KEY_ID: minioadmin\n      S3_BUCKET: evorto-ci\n      S3_ENDPOINT: http://minio:9000\n      S3_REGION: us-east-1\n      S3_SECRET_ACCESS_KEY: minioadmin\n      BUILDKIT_BUN_CACHE_DIR: buildkit-bun-cache\n      DOCKER_BUILD_CACHE_DIR: /tmp/evorto-docker-build-cache\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n\n      - name: Set up Bun dependency caches\n        id: bun-dependency-caches\n        uses: ./.github/actions/setup-bun-dependency-caches\n\n      - name: Set up Docker Buildx\n        id: setup-buildx\n        uses: docker/setup-buildx-action@v4\n        with:\n          version: latest\n\n      - name: Restore Docker build cache\n        uses: actions/cache/restore@v4\n        with:\n          path: ${{ env.DOCKER_BUILD_CACHE_DIR }}\n          key: ${{ runner.os }}-docker-build-bun-1.3.11-${{ hashFiles('Dockerfile', 'docker-compose.yml', '.github/docker-compose.build-cache.yml', 'package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-docker-build-bun-1.3.11-\n\n      - name: Restore Docker Bun cache mount\n        id: docker-bun-cache-mount\n        uses: actions/cache/restore@v4\n        with:\n          path: ${{ env.BUILDKIT_BUN_CACHE_DIR }}\n          key: ${{ runner.os }}-docker-bun-cache-mount-1.3.11-${{ hashFiles('package.json', 'bun.lock', 'bunfig.toml', 'patches/**') }}\n          restore-keys: |\n            ${{ runner.os }}-docker-bun-cache-mount-1.3.11-\n\n      - name: Require warmed Docker Bun cache mount\n        run: |\n          echo \"Docker Bun cache mount hit: ${{ steps.docker-bun-cache-mount.outputs.cache-hit }}\"\n          if [ \"${{ steps.docker-bun-cache-mount.outputs.cache-hit }}\" != \"true\" ]; then\n            echo \"::error::Docker Bun cache mount was not restored after warm-ci-caches. Refusing Docker builds that could repeat Font Awesome package downloads inside each E2E worker.\"\n            exit 1\n          fi\n\n      - name: Inject Docker Bun cache mount\n        uses: reproducible-containers/buildkit-cache-dance@v3.4.0\n        with:\n          builder: ${{ steps.setup-buildx.outputs.name }}\n          cache-map: |\n            {\n              \"${{ env.BUILDKIT_BUN_CACHE_DIR }}\": {\n                \"target\": \"/home/bun/.bun/install/cache\",\n                \"id\": \"bun-install-cache\"\n              }\n            }\n          skip-extraction: true\n\n      - name: Restore Playwright browser cache\n        uses: actions/cache/restore@v4\n        with:\n          path: ~/.cache/ms-playwright\n          key: ${{ runner.os }}-playwright-1.59.1-chromium\n          restore-keys: |\n            ${{ runner.os }}-playwright-1.59.1-\n\n      - name: Prepare Docker build cache directory\n        run: mkdir -p \"${DOCKER_BUILD_CACHE_DIR}\"\n\n      - name: Validate required configuration\n        run: |\n          if [ -z \"${NEON_API_KEY}\" ]; then\n            echo \"::error::Missing required secret: NEON_API_KEY\"\n            exit 1\n          fi\n          if [ -z \"${NEON_PROJECT_ID}\" ]; then\n            echo \"::error::Missing required repository variable: NEON_PROJECT_ID\"\n            exit 1\n          fi\n          if [ -z \"${PARENT_BRANCH_ID}\" ]; then\n            echo \"::notice::PARENT_BRANCH_ID is not configured; resolving the Neon default branch for ephemeral E2E branches.\"\n            set +e\n            resolved_parent_branch_id=\"$(\n              curl --fail --silent --show-error \\\n                --header \"Accept: application/json\" \\\n                --header \"Authorization: Bearer ${NEON_API_KEY}\" \\\n                \"https://console.neon.tech/api/v2/projects/${NEON_PROJECT_ID}/branches\" |\n                node --input-type=module -e '\n                  let input = \"\";\n                  process.stdin.setEncoding(\"utf8\");\n                  process.stdin.on(\"data\", (chunk) => {\n                    input += chunk;\n                  });\n                  process.stdin.on(\"end\", () => {\n                    const payload = JSON.parse(input);\n                    const branches = Array.isArray(payload.branches)\n                      ? payload.branches\n                      : [];\n                    const branch =\n                      branches.find(\n                        (candidate) =>\n                          candidate.default === true &&\n                          candidate.primary === true,\n                      ) ??\n                      branches.find((candidate) => candidate.name === \"main\") ??\n                      branches.find(\n                        (candidate) => candidate.default === true,\n                      );\n\n                    if (typeof branch?.id !== \"string\" || !branch.id.trim()) {\n                      process.exit(1);\n                    }\n\n                    process.stdout.write(branch.id.trim());\n                  });\n                '\n            )\"\n            resolve_status=$?\n            set -e\n\n            if [ \"${resolve_status}\" != \"0\" ] || [ -z \"${resolved_parent_branch_id}\" ]; then\n              echo \"::error::Unable to resolve a Neon parent branch for E2E. Set PARENT_BRANCH_ID or ensure NEON_API_KEY can list project branches.\"\n              exit 1\n            fi\n\n            export PARENT_BRANCH_ID=\"${resolved_parent_branch_id}\"\n            echo \"PARENT_BRANCH_ID=${PARENT_BRANCH_ID}\" >> \"${GITHUB_ENV}\"\n          fi\n          if [ -z \"${STRIPE_TEST_ACCOUNT_ID}\" ]; then\n            echo \"::error::Missing required Stripe connected account id. Set STRIPE_TEST_ACCOUNT_ID as a secret or repository variable.\"\n            exit 1\n          fi\n          if [ -z \"${CLIENT_SECRET}\" ]; then\n            echo \"::error::Missing required secret: CLIENT_SECRET\"\n            exit 1\n          fi\n          if [ -z \"${ISSUER_BASE_URL}\" ]; then\n            echo \"::error::Missing required Auth0 issuer URL. Set ISSUER_BASE_URL as a secret or repository variable.\"\n            exit 1\n          fi\n          if [ -z \"${SECRET}\" ]; then\n            echo \"::error::Missing required secret: SECRET\"\n            exit 1\n          fi\n          if [ -z \"${STRIPE_API_KEY}\" ]; then\n            echo \"::error::Missing required secret: STRIPE_API_KEY\"\n            exit 1\n          fi\n\n      - name: Prune expired Neon branches before E2E\n        run: bun helpers/testing/delete-neon-local-branches.ts\n\n      - name: Install dependencies\n        env:\n          BUN_DEPENDENCY_TREE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-hit }}\n          BUN_PACKAGE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.package-cache-hit }}\n          CI_DEPENDENCY_INSTALL_MISSING_CACHE_MESSAGE: Bun dependency tree cache was not restored after warm-ci-caches. Refusing a parallel registry install to avoid repeated Font Awesome package downloads.\n          CI_DEPENDENCY_INSTALL_MODE: offline-required\n        run: bash helpers/testing/install-ci-dependencies.sh\n\n      - name: Save Bun dependency tree from package cache\n        if: steps.bun-dependency-caches.outputs.dependency-tree-cache-hit != 'true'\n        uses: actions/cache/save@v4\n        with:\n"}}
{"timestamp":"2026-06-05T09:57:41.833Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_ztuYwX7bMRw1o6UZ05n4veND","output":"Chunk ID: e95ed1\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 874\nOutput:\nname: \"Copilot Setup Steps\"\n\n# Automatically run the setup steps when they are changed to allow for easy validation, and\n# allow manual testing through the repository's \"Actions\" tab\non:\n  workflow_dispatch:\n  push:\n    paths:\n      - .github/workflows/copilot-setup-steps.yml\n      - .github/actions/setup-bun-dependency-caches/action.yml\n  pull_request:\n    paths:\n      - .github/workflows/copilot-setup-steps.yml\n      - .github/actions/setup-bun-dependency-caches/action.yml\n\nenv:\n  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true\n  PLAYWRIGHT_BROWSERS_PATH: /home/runner/.cache/ms-playwright\n\njobs:\n  # The job MUST be called `copilot-setup-steps` or it will not be picked up by Copilot.\n  copilot-setup-steps:\n    runs-on: ubuntu-latest\n    env:\n      AUTH0_MANAGEMENT_CLIENT_ID: ${{ secrets.AUTH0_MANAGEMENT_CLIENT_ID }}\n      AUTH0_MANAGEMENT_CLIENT_SECRET: ${{ secrets.AUTH0_MANAGEMENT_CLIENT_SECRET }}\n      CLIENT_ID: ${{ secrets.CLIENT_ID }}\n      CLIENT_SECRET: ${{ secrets.CLIENT_SECRET }}\n      CLOUDFLARE_IMAGES_API_TOKEN: ${{ secrets.CLOUDFLARE_IMAGES_API_TOKEN }}\n      DATABASE_URL: ${{ secrets.DATABASE_URL }}\n      NEON_API_KEY: ${{ secrets.NEON_API_KEY }}\n      S3_ACCESS_KEY_ID: ${{ secrets.CLOUDFLARE_R2_S3_KEY_ID }}\n      S3_SECRET_ACCESS_KEY: ${{ secrets.CLOUDFLARE_R2_S3_KEY }}\n      STRIPE_API_KEY: ${{ secrets.STRIPE_API_KEY }}\n      STRIPE_WEBHOOK_SECRET: ${{ secrets.STRIPE_WEBHOOK_SECRET }}\n\n    # Set the permissions to the lowest permissions possible needed for your steps.\n    # Copilot will be given its own token for its operations.\n    permissions:\n      # If you want to clone the repository as part of your setup steps, for example to install dependencies, you'll need the `contents: read` permission. If you don't clone the repository in your setup steps, Copilot will do this for you automatically after the steps complete.\n      contents: read\n\n    # You can define any steps you want, and they will run before the agent starts.\n    # If you do not check out your code, Copilot will do this for you.\n    steps:\n      - name: Checkout code\n        uses: actions/checkout@v4\n\n      - name: Set up Bun dependency caches\n        id: bun-dependency-caches\n        uses: ./.github/actions/setup-bun-dependency-caches\n\n      - name: Install dependencies\n        env:\n          BUN_DEPENDENCY_TREE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-hit }}\n          BUN_PACKAGE_CACHE_HIT: ${{ steps.bun-dependency-caches.outputs.package-cache-hit }}\n          CI_DEPENDENCY_INSTALL_MISSING_CACHE_MESSAGE: Bun dependency tree cache was not restored for Copilot setup. Refusing a registry install to avoid repeated Font Awesome package downloads.\n          CI_DEPENDENCY_INSTALL_MODE: offline-required\n        run: bash helpers/testing/install-ci-dependencies.sh\n\n      - name: Save Bun dependency tree from package cache\n        if: steps.bun-dependency-caches.outputs.dependency-tree-cache-hit != 'true'\n        uses: actions/cache/save@v4\n        with:\n          path: node_modules\n          key: ${{ steps.bun-dependency-caches.outputs.dependency-tree-cache-primary-key }}\n\n      - name: Restore Playwright browser cache\n        uses: actions/cache@v4\n        with:\n          path: ~/.cache/ms-playwright\n          key: ${{ runner.os }}-playwright-1.59.1-chromium\n          restore-keys: |\n            ${{ runner.os }}-playwright-1.59.1-\n\n      - name: Install Playwright browsers\n        run: node_modules/.bin/playwright install --with-deps\n"}}
{"timestamp":"2026-06-05T09:57:41.836Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_SlWCY1Z82HSpv5wigk3VLyvU","output":"Chunk ID: 0012fb\nWall time: 0.0000 seconds\nProcess exited with code 0\nOriginal token count: 310\nOutput:\nname: Neon Branch Cleanup\n\non:\n  workflow_dispatch:\n  schedule:\n    - cron: \"17 * * * *\"\n  workflow_run:\n    workflows: [\"E2E Baseline\"]\n    types: [completed]\n\npermissions:\n  contents: read\n\nconcurrency:\n  group: neon-branch-cleanup\n  cancel-in-progress: false\n\nenv:\n  DELETE_BRANCH: true\n  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true\n  NEON_API_KEY: ${{ secrets.NEON_API_KEY }}\n  NEON_LOCAL_BRANCH_TTL_HOURS: 2\n  NEON_PROJECT_ID: ${{ vars.NEON_PROJECT_ID }}\n\njobs:\n  cleanup:\n    name: Prune stale Neon Local branches\n    runs-on: ubuntu-latest\n    timeout-minutes: 10\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n\n      - name: Setup Bun\n        uses: oven-sh/setup-bun@v2\n        with:\n          bun-version: \"1.3.11\"\n\n      - name: Validate required configuration\n        run: |\n          if [ -z \"${NEON_API_KEY}\" ]; then\n            echo \"::error::Missing required secret: NEON_API_KEY\"\n            exit 1\n          fi\n          if [ -z \"${NEON_PROJECT_ID}\" ]; then\n            echo \"::error::Missing required repository variable: NEON_PROJECT_ID\"\n            exit 1\n          fi\n\n      - name: Prune branches outside the active-test TTL\n        run: bun helpers/testing/delete-neon-local-branches.ts\n"}}
